<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Horarios - Schedule Management Service</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        .section {
            display: none;
        }

        .section.active {
            display: block;
            animation: fadeIn 0.4s ease-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(5px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .glass {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
        }
    </style>
</head>

<body class="bg-slate-50 text-slate-800 font-sans h-screen flex overflow-hidden">

    <!-- ==============================================
         MÓDULO DE LOGIN
    =============================================== -->
    <div id="login-container" class="fixed inset-0 bg-slate-900 z-[9999] flex items-center justify-center">
        <div class="bg-white p-8 rounded-2xl shadow-2xl w-full max-w-sm animate-in zoom-in duration-300">
            <div class="text-center mb-8">
                <i class="fa-solid fa-shield-halved text-4xl text-indigo-600 mb-3 block"></i>
                <h2 class="text-2xl font-black text-slate-900 tracking-tight">Acceso Restringido</h2>
                <p class="text-slate-500 text-sm mt-1">Ingresa con tu cuenta @vonex.edu.pe</p>
            </div>
            <form id="login-form" autocomplete="off">
                <div class="mb-4">
                    <label class="block text-xs font-black text-slate-500 mb-2 uppercase tracking-wide">Usuario
                        Institucional</label>
                    <input type="email" id="login-username" required
                        class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 font-medium text-slate-700"
                        placeholder="ejemplo@vonex.edu.pe">
                </div>
                <div class="mb-6">
                    <label
                        class="block text-xs font-black text-slate-500 mb-2 uppercase tracking-wide">Contraseña</label>
                    <input type="password" id="login-password" required
                        class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 font-medium text-slate-700"
                        placeholder="••••••••">
                </div>
                <div id="login-error"
                    class="hidden mb-4 bg-rose-50 border border-rose-200 text-rose-700 text-xs font-bold p-3 rounded-lg text-center">
                </div>
                <button type="submit" id="login-btn"
                    class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-black py-3.5 rounded-xl shadow-lg transition-all flex justify-center items-center gap-2">
                    Ingresar <i class="fa-solid fa-arrow-right"></i>
                </button>
            </form>
        </div>
    </div>

    <!-- ==============================================
         APP PRINCIPAL (OCULTA HASTA LOGIN)
    =============================================== -->
    <div id="app-container" class="flex w-full h-full" style="display: none;">


        <!-- Sidebar -->
        <aside class="w-64 bg-slate-900 text-white flex flex-col shadow-xl z-20">
            <div class="p-6 border-b border-slate-800">
                <h1 class="text-xl font-bold flex items-center gap-3">
                    <i class="fa-solid fa-calendar-days text-indigo-400"></i>
                    Gestión Horarios
                </h1>
                <p class="text-slate-400 text-xs mt-2 uppercase tracking-wider font-semibold">Microservice Admin</p>
            </div>

            <nav class="flex-1 px-4 py-6 space-y-2">
                <button onclick="nav('upload')"
                    class="nav-btn w-full flex items-center gap-3 px-4 py-3 bg-indigo-600 hover:bg-indigo-700 rounded-lg text-left transition-all font-medium shadow-md shadow-indigo-900/50">
                    <i class="fa-solid fa-file-arrow-up w-5"></i> Subir XML
                </button>
                <button onclick="nav('schedule')"
                    class="nav-btn w-full flex items-center gap-3 px-4 py-3 hover:bg-slate-800 rounded-lg text-left transition-all text-slate-300 hover:text-white">
                    <i class="fa-solid fa-table-cells w-5"></i> Ver Horarios
                </button>
                <!-- BOTÓN OBSOLETO: El RPT Planillas ya absorbió el Sistema de Conteo de Horas.
            <button onclick="nav('hours')" class="nav-btn w-full flex items-center gap-3 px-4 py-3 hover:bg-slate-800 rounded-lg text-left transition-all text-slate-300 hover:text-white">
                <i class="fa-solid fa-clock w-5"></i> Conteo de Horas
            </button>
            -->
                <button onclick="nav('observations')"
                    class="nav-btn w-full flex items-center gap-3 px-4 py-3 hover:bg-slate-800 rounded-lg text-left transition-all text-slate-300 hover:text-white">
                    <i class="fa-solid fa-triangle-exclamation w-5"></i> Observaciones
                </button>
                <button onclick="nav('rpt-planilla')"
                    class="nav-btn w-full flex items-center gap-3 px-4 py-3 hover:bg-slate-800 rounded-lg text-left transition-all text-slate-300 hover:text-white">
                    <i class="fa-solid fa-table-list w-5"></i> RPT PLANILLAS
                </button>
                <button onclick="nav('docentes')"
                    class="nav-btn w-full flex items-center gap-3 px-4 py-3 hover:bg-slate-800 rounded-lg text-left transition-all text-slate-300 hover:text-white">
                    <i class="fa-solid fa-chalkboard-user w-5"></i> Docentes
                </button>

                <div class="pt-4 mt-4 border-t border-slate-800">
                    <p class="px-4 text-[10px] font-black text-slate-500 uppercase tracking-widest mb-2">Administración
                    </p>


                    <!-- Módulo Usuarios -->
                    <button id="nav-btn-usuarios" onclick="nav('usuarios-module')" style="display: none;"
                        class="nav-btn w-full flex items-center gap-3 px-4 py-3 hover:bg-slate-800 rounded-lg text-left transition-all text-slate-300 hover:text-white mt-1">
                        <i class="fa-solid fa-user-shield w-5 text-center"></i> Control de Usuarios
                    </button>

                    <!-- Menú Desplegable Configuración -->
                    <div class="px-2">
                        <button onclick="toggleConfigMenu()"
                            class="w-full flex items-center justify-between gap-3 px-4 py-3 hover:bg-slate-800 rounded-lg text-left transition-all text-slate-300 hover:text-white group">
                            <div class="flex items-center gap-3">
                                <i class="fa-solid fa-gears w-5"></i>
                                <span>Configuración</span>
                            </div>
                            <i id="config-chevron"
                                class="fa-solid fa-chevron-down text-[10px] transition-transform"></i>
                        </button>

                        <div id="config-submenu"
                            class="hidden pl-8 pr-2 py-2 space-y-1 animate-in slide-in-from-top-1 duration-200">
                            <button onclick="nav('recess-config')"
                                class="w-full flex items-center gap-3 px-4 py-2 hover:bg-slate-800 rounded-lg text-left transition-all text-sm text-slate-400 hover:text-white">
                                <i class="fa-solid fa-mug-hot w-4 text-center"></i> Recesos
                            </button>
                            <button onclick="nav('lunch-config')"
                                class="w-full flex items-center gap-3 px-4 py-2 hover:bg-slate-800 rounded-lg text-left transition-all text-sm text-slate-400 hover:text-white">
                                <i class="fa-solid fa-utensils w-4 text-center"></i> Almuerzos
                            </button>
                        </div>
                    </div>
                </div>
            </nav>

            <div class="p-5 border-t border-slate-800 bg-slate-800/50">
                <div class="flex items-center gap-3">
                    <div
                        class="w-10 h-10 rounded-full bg-indigo-500 flex items-center justify-center font-bold text-lg shadow-inner">
                        A
                    </div>
                    <div>
                        <p class="text-sm font-bold text-slate-200" id="current-username-display">Usuario</p><button
                            onclick="logout()"
                            class="text-xs text-rose-400 hover:text-rose-300 underline font-black">Cerrar
                            Sesión</button>
                        <p class="text-xs text-indigo-400">Administrador</p>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 overflow-y-auto p-10 relative bg-slate-50">

            <!-- Upload Section -->
            <div id="upload" class="section active max-w-4xl mx-auto">
                <div class="mb-8">
                    <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">Procesar Archivo XML</h2>
                    <p class="text-slate-500 mt-2">Sube la exportación de ASC Timetables para generar las sesiones de
                        clases.</p>
                </div>

                <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
                    <div class="grid grid-cols-2 gap-6 mb-8">
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-2">Fecha Inicio</label>
                            <input type="date" id="start-date"
                                class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all shadow-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-2">Fecha Fin</label>
                            <input type="date" id="end-date"
                                class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all shadow-sm">
                        </div>
                    </div>

                    <div id="drop-zone"
                        class="border-2 border-dashed border-slate-300 rounded-2xl p-14 text-center hover:bg-indigo-50 hover:border-indigo-400 transition-all cursor-pointer group"
                        onclick="document.getElementById('file-upload').click()">
                        <div
                            class="w-20 h-20 bg-indigo-100 text-indigo-500 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                            <i class="fa-solid fa-cloud-arrow-up text-3xl"></i>
                        </div>
                        <h3 id="file-name-display" class="text-xl font-bold text-slate-700">Arrastra tu XML aquí</h3>
                        <p class="text-slate-500 mt-2 text-sm">Sólo archivos provenientes de ASC Timetables</p>
                        <input type="file" id="file-upload" class="hidden" accept=".xml">
                    </div>

                    <div class="mt-8 flex justify-end">
                        <button id="upload-btn" onclick="simulateUpload()"
                            class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3.5 px-8 rounded-xl shadow-lg shadow-indigo-600/30 transition-all transform hover:-translate-y-0.5 flex items-center gap-2">
                            <i class="fa-solid fa-wand-magic-sparkles"></i>
                            Vincular y Procesar
                        </button>
                    </div>
                </div>

                <!-- Upload Progress -->
                <div id="upload-progress"
                    class="hidden mt-6 p-6 bg-white rounded-2xl shadow-sm border border-slate-200">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="font-bold text-slate-800 flex items-center gap-2">
                            <i class="fa-solid fa-circle-notch fa-spin text-indigo-500"></i> Normalizando datos...
                        </h3>
                        <span id="progress-status"
                            class="text-xs font-bold text-indigo-600 bg-indigo-100 px-3 py-1 rounded-full">Procesando</span>
                    </div>
                    <div class="w-full bg-slate-100 rounded-full h-3 mb-3 overflow-hidden">
                        <div id="progress-bar-fill" class="bg-indigo-500 h-3 rounded-full"
                            style="width: 0%; transition: width 0.5s ease;"></div>
                    </div>
                    <ul class="text-sm text-slate-500 space-y-1">
                        <li id="task-subjects"><i class="fa-regular fa-clock mr-2"></i> Extracción de Subjects</li>
                        <li id="task-teachers"><i class="fa-regular fa-clock mr-2"></i> Extracción de Docentes</li>
                        <li id="task-lessons" class="opacity-50"><i class="fa-regular fa-clock mr-2"></i> Generando
                            Lesson
                            Cards...</li>
                    </ul>
                </div>

                <!-- Conflict Alert -->
                <div id="conflict-alert"
                    class="hidden mt-6 bg-amber-50 border border-amber-200 p-6 rounded-2xl shadow-sm relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-1.5 h-full bg-amber-500"></div>
                    <div class="flex items-start gap-4 pl-2">
                        <div
                            class="w-10 h-10 bg-amber-100 rounded-full flex items-center justify-center flex-shrink-0 text-amber-600">
                            <i class="fa-solid fa-triangle-exclamation text-lg"></i>
                        </div>
                        <div class="flex-1">
                            <h3 class="font-bold text-amber-900 text-lg">Conflictos detectados en el Horario (2)</h3>
                            <p class="text-amber-700 text-sm mt-1">El ScheduleBuilderService detectó colisiones lógicas.
                                ¿Deseas sobrescribirlas?</p>

                            <div class="mt-4 space-y-2">
                                <div
                                    class="bg-white/60 p-3 rounded-lg border border-amber-200 text-sm text-amber-900 flex gap-3 shadow-sm">
                                    <i class="fa-solid fa-user-xmark mt-1 text-rose-500"></i>
                                    <div>El docente <b>Juan Pérez</b> está asignado a <b>Aula 101</b> y <b>Aula 102</b>
                                        simultáneamente el Lunes a las 08:00.</div>
                                </div>
                                <div
                                    class="bg-white/60 p-3 rounded-lg border border-amber-200 text-sm text-amber-900 flex gap-3 shadow-sm">
                                    <i class="fa-solid fa-building-circle-exclamation mt-1 text-rose-500"></i>
                                    <div><b>Aula 205</b> tiene asignado <b>Física(F+20)</b> y <b>Química</b> en el mismo
                                        bloque del Miércoles.</div>
                                </div>
                            </div>

                            <div class="mt-6 flex gap-3">
                                <button id="overwrite-btn"
                                    class="bg-amber-500 hover:bg-amber-600 text-white px-5 py-2.5 rounded-lg text-sm font-bold transition-all shadow-md shadow-amber-500/20"
                                    onclick="simulateUpload(true)">Aplicar Sobrescritura Force</button>
                                <button
                                    class="bg-white border border-slate-300 text-slate-700 hover:bg-slate-50 px-5 py-2.5 rounded-lg text-sm font-bold transition-all"
                                    onclick="resetUpload()">Cancelar Proceso</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Overwrite Confirmation Modal -->
                <div id="overwrite-modal"
                    class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm">
                    <div
                        class="bg-white rounded-2xl shadow-2xl max-w-md w-full overflow-hidden animate-in zoom-in duration-300">
                        <div class="p-6 text-center">
                            <div
                                class="w-16 h-16 bg-amber-100 text-amber-600 rounded-full flex items-center justify-center mx-auto mb-4">
                                <i class="fa-solid fa-arrows-rotate text-2xl"></i>
                            </div>
                            <h3 class="text-xl font-bold text-slate-900 mb-2">¿Sobrescribir datos existentes?</h3>
                            <p id="overwrite-modal-msg" class="text-slate-500 text-sm mb-6">Ya existen registros para
                                las
                                fechas seleccionadas en la tabla rpt_planilla. ¿Deseas reemplazarlos?</p>
                            <div class="flex gap-3">
                                <button onclick="confirmOverwrite()"
                                    class="flex-1 bg-amber-500 hover:bg-amber-600 text-white font-bold py-3 rounded-xl shadow-lg shadow-amber-500/30 transition-all">Sí,
                                    Sobrescribir</button>
                                <button onclick="closeOverwriteModal()"
                                    class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold py-3 rounded-xl transition-all">Cancelar</button>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Historial de Subidas -->
                <div class="mt-10 p-6 bg-white rounded-2xl shadow-sm border-2 border-indigo-200">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="text-xl font-bold text-slate-800 flex items-center gap-2">
                            <i class="fa-solid fa-clock-rotate-left text-indigo-500"></i> Historial de Subidas
                        </h3>
                        <button onclick="loadUploadHistory()"
                            class="text-sm font-bold text-indigo-600 hover:text-indigo-800 flex items-center gap-1 bg-indigo-50 px-3 py-1.5 rounded-lg transition-colors">
                            <i class="fa-solid fa-arrows-rotate"></i> Actualizar Historial
                        </button>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-indigo-50/50">
                                    <th
                                        class="px-4 py-3 text-xs font-black text-indigo-700 uppercase tracking-tighter border-b border-indigo-100">
                                        Fecha y Hora</th>
                                    <th
                                        class="px-4 py-3 text-xs font-black text-indigo-700 uppercase tracking-tighter border-b border-indigo-100">
                                        Archivo</th>
                                    <th
                                        class="px-4 py-3 text-xs font-black text-indigo-700 uppercase tracking-tighter border-b border-indigo-100">
                                        Rango</th>
                                    <th
                                        class="px-4 py-3 text-xs font-black text-indigo-700 uppercase tracking-tighter border-b border-indigo-100 text-center">
                                        ¿Overwrite?</th>
                                </tr>
                            </thead>
                            <tbody id="upload-history-body" class="divide-y divide-slate-100 text-sm">
                                <!-- Datos dinámicos -->
                            </tbody>
                        </table>
                    </div>
                    <!-- Pagination Controls -->
                    <div class="mt-6 flex items-center justify-between border-t border-slate-100 pt-4">
                        <div class="text-xs text-slate-500 font-medium">
                            Mostrando <span id="history-total" class="font-bold text-indigo-600">0</span> registros
                        </div>
                        <div class="flex items-center gap-2">
                            <button id="prev-page-btn" onclick="changeHistoryPage(-1)" disabled
                                class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white text-slate-400 hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed transition-all">
                                <i class="fa-solid fa-chevron-left mr-1"></i> Anterior
                            </button>
                            <span id="page-indicator"
                                class="text-xs font-bold text-slate-700 px-3 py-1.5 bg-slate-50 rounded-lg">Pagina 1 de
                                1</span>
                            <button id="next-page-btn" onclick="changeHistoryPage(1)" disabled
                                class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white text-slate-400 hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed transition-all">
                                Siguiente <i class="fa-solid fa-chevron-right ml-1"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Schedule Section -->
            <div id="schedule" class="section max-w-6xl mx-auto">
                <div class="flex justify-between items-center mb-8">
                    <div>
                        <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">Visor de Horarios</h2>
                        <p class="text-slate-500 mt-2">Consulta sesiones generadas por Docente o Aula.</p>
                    </div>
                    <button id="export-excel-btn" onclick="exportSchedule()"
                        class="bg-white border border-slate-300 text-slate-700 px-5 py-2.5 rounded-xl hover:bg-slate-50 shadow-sm font-semibold flex items-center gap-2 transition-colors">
                        <i class="fa-solid fa-download"></i> Exportar a Excel
                    </button>
                </div>

                <div
                    class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 mb-6 flex flex-wrap lg:flex-nowrap gap-5 items-end">
                    <div class="w-full lg:w-1/4">
                        <label class="block text-xs font-bold text-slate-500 mb-2 uppercase tracking-wide">Filtro de
                            Vista</label>
                        <select id="schedule-filter-type"
                            class="w-full px-4 py-2.5 bg-slate-50 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-medium text-slate-700">
                            <option value="teacher">Horario por Docente</option>
                            <option value="classroom">Horario por Aula</option>
                        </select>
                    </div>
                    <div class="w-full lg:w-1/4">
                        <label
                            class="block text-xs font-bold text-slate-500 mb-2 uppercase tracking-wide">Selección</label>
                        <select id="schedule-filter-target"
                            class="w-full px-4 py-2.5 bg-slate-50 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-medium text-slate-700">
                            <option value="">Cargando...</option>
                        </select>
                    </div>
                    <div class="w-full lg:w-1/4">
                        <label class="block text-xs font-bold text-slate-500 mb-2 uppercase tracking-wide">Fecha
                            Inicio</label>
                        <input type="date" id="schedule-start-date"
                            class="w-full px-4 py-2.5 bg-slate-50 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 font-medium text-slate-700">
                    </div>
                    <div class="w-full lg:w-1/4">
                        <label class="block text-xs font-bold text-slate-500 mb-2 uppercase tracking-wide">Fecha
                            Fin</label>
                        <input type="date" id="schedule-end-date"
                            class="w-full px-4 py-2.5 bg-slate-50 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 font-medium text-slate-700">
                    </div>
                    <div class="w-full lg:w-48">
                        <button onclick="loadSchedule()"
                            class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2.5 rounded-xl shadow-md shadow-indigo-600/20 transition-all flex items-center justify-center gap-2">
                            <i class="fa-solid fa-filter"></i> Filtrar
                        </button>
                    </div>
                </div>

                <!-- Teacher View Summary Panel -->
                <div id="schedule-teacher-summary"
                    class="hidden mb-6 bg-indigo-50 border-2 border-indigo-100 rounded-2xl p-6 flex flex-wrap gap-8 items-center shadow-sm">
                    <div class="flex items-center gap-4 text-center sm:text-left">
                        <div
                            class="w-12 h-12 bg-indigo-600 text-white rounded-xl flex items-center justify-center text-xl shadow-lg shrink-0">
                            <i class="fa-solid fa-user-tie"></i>
                        </div>
                        <div>
                            <p
                                class="text-[10px] font-black text-indigo-400 uppercase tracking-widest leading-none mb-1">
                                Docente</p>
                            <h3 id="sch-summary-name" class="text-xl font-black text-slate-800 leading-none">---</h3>
                        </div>
                    </div>
                    <div class="flex items-center gap-4 text-center sm:text-left">
                        <div
                            class="w-12 h-12 bg-amber-500 text-white rounded-xl flex items-center justify-center text-xl shadow-lg shrink-0">
                            <i class="fa-solid fa-calendar-week"></i>
                        </div>
                        <div>
                            <p
                                class="text-[10px] font-black text-amber-600/60 uppercase tracking-widest leading-none mb-1">
                                Rango de Semana</p>
                            <h3 id="sch-summary-range" class="text-xl font-black text-slate-800 leading-none">---</h3>
                        </div>
                    </div>
                    <div class="sm:ml-auto flex items-center gap-6 text-center sm:text-right">
                        <div>
                            <p
                                class="text-[10px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">
                                Total Horas</p>
                            <h3 id="sch-summary-hours"
                                class="text-3xl font-black text-indigo-700 leading-none tracking-tighter">0.00</h3>
                        </div>
                        <div class="border-l border-slate-200 pl-6">
                            <p
                                class="text-[10px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">
                                Total Recesos</p>
                            <h3 id="sch-summary-breaks"
                                class="text-3xl font-black text-amber-600 leading-none tracking-tighter">0.00</h3>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm text-left border-collapse">
                            <thead
                                class="text-xs text-slate-700 uppercase bg-slate-100 border-b-2 border-slate-200 font-black sticky top-0 z-20">
                                <tr>
                                    <th id="schedule-header-hour"
                                        class="px-4 py-3 w-28 text-center border-r border-slate-200 tracking-wider bg-slate-100">
                                        Horario</th>
                                    <th
                                        class="px-4 py-3 border-r border-slate-200 text-center tracking-wider bg-slate-100">
                                        Lunes 13</th>
                                    <th
                                        class="px-4 py-3 border-r border-slate-200 text-center tracking-wider bg-slate-100">
                                        Martes 14</th>
                                    <th
                                        class="px-4 py-3 border-r border-slate-200 text-center tracking-wider bg-slate-100">
                                        Miércoles 15</th>
                                    <th
                                        class="px-4 py-3 border-r border-slate-200 text-center tracking-wider bg-slate-100">
                                        Jueves 16</th>
                                    <th class="px-4 py-3 text-center tracking-wider bg-slate-100">Viernes 17</th>
                                </tr>
                            </thead>
                            <tbody id="schedule-grid-body">
                                <!-- Dynamic Content Rendered Here -->
                                <tr class="border-b border-slate-200">
                                    <td colspan="6" class="p-8 text-center text-slate-400">Selecciona un docente o aula
                                        para
                                        visualizar su horario.</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Hours Section -->
            <div id="hours" class="section max-w-5xl mx-auto">
                <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight mb-2">Conteo de Horas</h2>
                <p class="text-slate-500 mb-8">Auditoría automática de tiempos totales y modificaciones de bloque.</p>

                <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                    <div class="p-6 border-b border-slate-200 flex justify-between items-center bg-slate-50/80">
                        <h3 class="font-bold text-slate-800 text-lg">Reporte Consolidado <span
                                class="text-sm font-normal text-slate-500 ml-2">(Marzo 2026)</span></h3>
                        <div class="relative">
                            <i class="fa-solid fa-search absolute left-3 top-3 text-slate-400"></i>
                            <input type="text" placeholder="Buscar docente..."
                                class="pl-10 pr-4 py-2 border border-slate-300 rounded-xl text-sm w-72 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-white shadow-sm">
                        </div>
                    </div>
                    <table class="w-full text-sm text-left">
                        <thead class="text-xs text-slate-600 uppercase bg-white border-b border-slate-200 font-bold">
                            <tr>
                                <th class="px-6 py-4">Docente Registrado</th>
                                <th class="px-6 py-4 text-center">Horas Base</th>
                                <th class="px-6 py-4 text-center">Modificadores (F+, I-)</th>
                                <th class="px-6 py-4 text-center text-indigo-700">Tiempo Real Calculado</th>
                                <th class="px-6 py-4 text-right">Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="border-b border-slate-100 hover:bg-slate-50/50 transition-colors">
                                <td class="px-6 py-5 font-bold text-slate-800">
                                    <div class="flex items-center gap-4">
                                        <div
                                            class="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-500 to-purple-500 text-white flex items-center justify-center font-bold shadow-sm">
                                            JP</div>
                                        Juan Pérez
                                    </div>
                                </td>
                                <td class="px-6 py-5 text-center text-slate-600 font-medium tracking-wide">20 h 00 m
                                </td>
                                <td class="px-6 py-5 text-center text-emerald-600 font-bold"><i
                                        class="fa-solid fa-plus text-[10px] mr-1"></i>1 h 30 m</td>
                                <td class="px-6 py-5 text-center font-black text-indigo-900 text-base bg-indigo-50/30">
                                    21 h
                                    30 m</td>
                                <td class="px-6 py-5 text-right">
                                    <button
                                        class="text-indigo-600 hover:text-white hover:bg-indigo-600 font-bold text-xs bg-indigo-50 border border-indigo-100 px-4 py-2 rounded-lg transition-colors">Auditar
                                        Bloques</button>
                                </td>
                            </tr>
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="px-6 py-5 font-bold text-slate-800">
                                    <div class="flex items-center gap-4">
                                        <div
                                            class="w-10 h-10 rounded-full bg-gradient-to-br from-rose-400 to-orange-400 text-white flex items-center justify-center font-bold shadow-sm">
                                            MG</div>
                                        María Gómez
                                    </div>
                                </td>
                                <td class="px-6 py-5 text-center text-slate-600 font-medium tracking-wide">18 h 00 m
                                </td>
                                <td class="px-6 py-5 text-center text-rose-600 font-bold">-0 h 30 m</td>
                                <td class="px-6 py-5 text-center font-black text-indigo-900 text-base bg-indigo-50/30">
                                    17 h
                                    30 m</td>
                                <td class="px-6 py-5 text-right">
                                    <button
                                        class="text-indigo-600 hover:text-white hover:bg-indigo-600 font-bold text-xs bg-indigo-50 border border-indigo-100 px-4 py-2 rounded-lg transition-colors">Auditar
                                        Bloques</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div id="observations" class="section max-w-7xl mx-auto">
                <div class="mb-8">
                    <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">Gestión de Incidencias y
                        Observaciones
                    </h2>
                    <p class="text-slate-500 mt-2">Registra faltas, reemplazos y otros eventos que afecten la planilla.
                    </p>
                </div>

                <!-- Tabs Navigation -->
                <div class="flex border-b border-slate-200 mb-8 overflow-x-auto">
                    <button onclick="toggleObsTab('register')" id="tab-btn-register"
                        class="px-8 py-4 text-sm font-black border-b-2 border-indigo-600 text-indigo-600 transition-all uppercase tracking-widest">
                        Registrar Incidencia
                    </button>
                    <button onclick="toggleObsTab('logs')" id="tab-btn-logs"
                        class="px-8 py-4 text-sm font-black border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all uppercase tracking-widest">
                        Logs de Cambios
                    </button>
                </div>

                <!-- Tab 1: Registrar Incidencia -->
                <div id="obs-tab-register" class="space-y-8">
                    <div
                        class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-wrap lg:flex-nowrap gap-5 items-end">
                        <div class="w-full lg:w-1/3">
                            <label
                                class="block text-xs font-black text-slate-500 mb-2 uppercase tracking-tighter">Seleccionar
                                Docente</label>
                            <select id="obs-filter-docente"
                                class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 font-medium text-slate-700 text-sm">
                                <option value="">Cargando docentes...</option>
                            </select>
                        </div>
                        <div class="w-full lg:w-1/4">
                            <label class="block text-xs font-black text-slate-500 mb-2 uppercase tracking-tighter">Fecha
                                Inicio</label>
                            <input type="date" id="obs-date-start"
                                class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 font-medium text-slate-700 text-sm">
                        </div>
                        <div class="w-full lg:w-1/4">
                            <label class="block text-xs font-black text-slate-500 mb-2 uppercase tracking-tighter">Fecha
                                Fin</label>
                            <input type="date" id="obs-date-end"
                                class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 font-medium text-slate-700 text-sm">
                        </div>
                        <div class="w-full lg:w-1/6">
                            <button onclick="searchClassesForObs()"
                                class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2.5 rounded-xl transition-all shadow-md shadow-indigo-600/20">
                                Buscar
                            </button>
                        </div>
                    </div>

                    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead>
                                    <tr class="bg-slate-50 border-b border-slate-200">
                                        <th
                                            class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Fecha</th>
                                        <th
                                            class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Curso</th>
                                        <th
                                            class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Ciclo</th>
                                        <th
                                            class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Horario</th>
                                        <th
                                            class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter text-center">
                                            Acción</th>
                                    </tr>
                                </thead>
                                <tbody id="obs-search-body" class="divide-y divide-slate-100 text-sm">
                                    <tr>
                                        <td colspan="5" class="px-4 py-12 text-center text-slate-400 font-medium">
                                            Ingresa los filtros para buscar sesiones de clase.
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Tab 2: Logs de Auditoría -->
                <div id="obs-tab-logs" class="hidden">
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead>
                                    <tr class="bg-slate-50 border-b border-slate-200">
                                        <th
                                            class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Fecha Registro</th>
                                        <th
                                            class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Usuario</th>
                                        <th
                                            class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Docente Afectado</th>
                                        <th
                                            class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Tipo</th>
                                        <th
                                            class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Fecha Clase</th>
                                        <th
                                            class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Observación</th>
                                    </tr>
                                </thead>
                                <tbody id="obs-logs-body" class="divide-y divide-slate-100 text-sm">
                                    <!-- Cargado por JS -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RPT Planillas Section -->
            <div id="rpt-planilla" class="section max-w-7xl mx-auto">
                <div class="flex justify-between items-center mb-8">
                    <div>
                        <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">RPT Planillas</h2>
                        <p class="text-slate-500 mt-2">Visualización, filtrado y exportación de datos de planilla.</p>
                    </div>
                    <button onclick="exportToExcel()"
                        class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-3 rounded-xl shadow-lg shadow-emerald-600/20 font-bold flex items-center gap-2 transition-all transform hover:-translate-y-0.5">
                        <i class="fa-solid fa-file-excel text-lg"></i> Exportar a Excel
                    </button>
                </div>

                <!-- Enhanced Filters -->
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 mb-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-5 items-end">
                        <div class="lg:col-span-1">
                            <label class="block text-xs font-black text-slate-500 mb-2 uppercase tracking-tighter">Fecha
                                Inicio</label>
                            <input type="date" id="rpt-fecha-inicio"
                                class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-medium text-slate-700 transition-all text-sm">
                        </div>
                        <div class="lg:col-span-1">
                            <label class="block text-xs font-black text-slate-500 mb-2 uppercase tracking-tighter">Fecha
                                Fin</label>
                            <input type="date" id="rpt-fecha-fin"
                                class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-medium text-slate-700 transition-all text-sm">
                        </div>
                        <div class="lg:col-span-1">
                            <label
                                class="block text-xs font-black text-slate-500 mb-2 uppercase tracking-tighter">Docente</label>
                            <select id="rpt-filter-docente"
                                class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-medium text-slate-700 transition-all text-sm">
                                <option value="Todos">Todos los Docentes</option>
                            </select>
                        </div>
                        <div class="lg:col-span-1">
                            <label
                                class="block text-xs font-black text-slate-500 mb-2 uppercase tracking-tighter">Sede</label>
                            <select id="rpt-filter-sede" onchange="handleSedeChange()"
                                class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-medium text-slate-700 transition-all text-sm">
                                <option value="Todas">Todas las Sedes</option>
                            </select>
                        </div>
                        <div class="lg:col-span-1">
                            <label class="block text-xs font-black text-slate-500 mb-2 uppercase tracking-tighter">Aula
                                /
                                Ciclo</label>
                            <select id="rpt-filter-aula" disabled
                                class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-medium text-slate-700 transition-all disabled:opacity-50 disabled:bg-slate-100 text-sm">
                                <option value="Todos">Todos</option>
                            </select>
                        </div>
                    </div>
                    <div class="mt-6 flex justify-end">
                        <button onclick="loadRptPlanilla(1)"
                            class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2.5 px-8 rounded-xl shadow-md shadow-indigo-600/20 transition-all flex items-center gap-2">
                            <i class="fa-solid fa-filter"></i> Filtrar Resultados
                        </button>
                    </div>
                </div>

                <!-- Summary Panel -->
                <div id="rpt-summary-panel" class="hidden mb-8 grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div
                        class="bg-white p-6 rounded-2xl shadow-sm border-2 border-indigo-100 flex items-center gap-5 transition-all hover:shadow-md">
                        <div
                            class="w-14 h-14 bg-indigo-100 text-indigo-600 rounded-2xl flex items-center justify-center text-2xl shadow-inner">
                            <i class="fa-solid fa-clock-pulse"></i>
                        </div>
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-0.5">Cantidad
                                de
                                horas dictadas</p>
                            <h3 id="rpt-sum-hours" class="text-3xl font-black text-slate-900 tracking-tight">0.00</h3>
                        </div>
                    </div>
                    <div
                        class="bg-white p-6 rounded-2xl shadow-sm border-2 border-amber-100 flex items-center gap-5 transition-all hover:shadow-md">
                        <div
                            class="w-14 h-14 bg-amber-100 text-amber-600 rounded-2xl flex items-center justify-center text-2xl shadow-inner">
                            <i class="fa-solid fa-mug-hot"></i>
                        </div>
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-0.5">Cantidad
                                de
                                recesos (0.33)</p>
                            <h3 id="rpt-count-recesos" class="text-3xl font-black text-slate-900 tracking-tight">0</h3>
                        </div>
                    </div>
                </div>

                <!-- Table -->
                <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-slate-50 border-b border-slate-200">
                                    <th class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                        Fecha
                                    </th>
                                    <th class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                        Sede
                                    </th>
                                    <th class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                        Ciclo
                                    </th>
                                    <th class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                        Docente</th>
                                    <th class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                        Curso
                                    </th>
                                    <th class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                        Inicio</th>
                                    <th class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                        Fin
                                    </th>
                                    <th
                                        class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter text-center">
                                        Horas</th>
                                    <th
                                        class="px-4 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter text-center">
                                        Receso</th>
                                </tr>
                            </thead>
                            <tbody id="rpt-planilla-body" class="divide-y divide-slate-100 text-sm">
                                <tr>
                                    <td colspan="9" class="px-4 py-12 text-center text-slate-400">
                                        <i class="fa-solid fa-spinner fa-spin text-2xl mb-3 block"></i>
                                        Cargando datos...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <div class="p-6 border-t border-slate-100 flex items-center justify-between bg-slate-50/50">
                        <div class="text-xs text-slate-500 font-medium">
                            Mostrando <span id="rpt-total-records" class="font-bold text-indigo-600">0</span> registros
                        </div>
                        <div class="flex items-center gap-2">
                            <button id="rpt-prev-btn" onclick="changeRptPage(-1)" disabled
                                class="px-4 py-2 text-xs font-bold rounded-xl border border-slate-200 bg-white text-slate-600 hover:bg-slate-100 disabled:opacity-50 transition-all shadow-sm">
                                <i class="fa-solid fa-chevron-left mr-1"></i> Anterior
                            </button>
                            <span id="rpt-page-indicator"
                                class="text-xs font-bold text-slate-700 px-4 py-2 bg-white border border-slate-200 rounded-xl shadow-sm">Página
                                1 de 1</span>
                            <button id="rpt-next-btn" onclick="changeRptPage(1)" disabled
                                class="px-4 py-2 text-xs font-bold rounded-xl border border-slate-200 bg-white text-slate-600 hover:bg-slate-100 disabled:opacity-50 transition-all shadow-sm">
                                Siguiente <i class="fa-solid fa-chevron-right ml-1"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <!-- ═══════════════════════════════════════════════════
             DOCENTES SECTION
             ═══════════════════════════════════════════════════ -->
            <div id="docentes" class="section max-w-7xl mx-auto">
                <div class="mb-8">
                    <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">Gestión de Docentes</h2>
                    <p class="text-slate-500 mt-2">Carga Excel, maestra de docentes y docentes sin asignar del XML.</p>
                </div>

                <!-- Sub-tabs -->
                <div class="flex border-b border-slate-200 mb-8 overflow-x-auto">
                    <button onclick="toggleDocentesTab('upload')" id="doc-tab-btn-upload"
                        class="doc-tab-btn px-8 py-4 text-sm font-black border-b-2 border-indigo-600 text-indigo-600 transition-all uppercase tracking-widest whitespace-nowrap">
                        <i class="fa-solid fa-file-excel mr-2"></i>Subir Docentes
                    </button>
                    <button onclick="toggleDocentesTab('maestra')" id="doc-tab-btn-maestra"
                        class="doc-tab-btn px-8 py-4 text-sm font-black border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all uppercase tracking-widest whitespace-nowrap">
                        <i class="fa-solid fa-users mr-2"></i>Maestra
                    </button>
                    <button onclick="toggleDocentesTab('sinasignar')" id="doc-tab-btn-sinasignar"
                        class="doc-tab-btn px-8 py-4 text-sm font-black border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all uppercase tracking-widest whitespace-nowrap">
                        <i class="fa-solid fa-user-clock mr-2"></i>Sin Asignar
                        <span id="sinasignar-badge"
                            class="hidden ml-2 bg-amber-500 text-white text-[10px] font-black px-2 py-0.5 rounded-full">0</span>
                    </button>
                    <button onclick="toggleDocentesTab('conflictos')" id="doc-tab-btn-conflictos"
                        class="doc-tab-btn px-8 py-4 text-sm font-black border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all uppercase tracking-widest whitespace-nowrap">
                        <i class="fa-solid fa-code-branch mr-2"></i>Revisión de Conflictos
                        <span id="conflictos-badge"
                            class="hidden ml-2 bg-rose-500 text-white text-[10px] font-black px-2 py-0.5 rounded-full">0</span>
                    </button>
                </div>

                <!-- Tab: Subir Excel -->
                <div id="doc-tab-upload-excel">
                    <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 w-full">
                        <h3 class="text-lg font-bold text-slate-800 mb-2">Importar desde Excel</h3>
                        <p class="text-sm text-slate-500 mb-6">Columnas requeridas: <strong>DNI | APELLIDOS | NOMBRES |
                                RAZON SOCIAL</strong></p>
                        <div id="doc-drop-zone"
                            class="border-2 border-dashed border-slate-300 rounded-2xl p-10 text-center hover:bg-indigo-50 hover:border-indigo-400 transition-all cursor-pointer group mb-6"
                            onclick="document.getElementById('doc-file-upload').click()">
                            <div
                                class="w-16 h-16 bg-indigo-100 text-indigo-500 rounded-full flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform">
                                <i class="fa-solid fa-file-arrow-up text-2xl"></i>
                            </div>
                            <p id="doc-file-name" class="font-bold text-slate-700">Arrastra tu Excel o haz clic aquí</p>
                            <p class="text-slate-400 text-xs mt-1">.xlsx / .xls</p>
                            <input type="file" id="doc-file-upload" class="hidden" accept=".xlsx,.xls">
                        </div>
                        <button onclick="uploadDocentesExcel()"
                            class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-8 rounded-xl shadow-md shadow-indigo-600/30 transition-all flex items-center gap-2">
                            <i class="fa-solid fa-wand-magic-sparkles"></i> Importar
                        </button>
                    </div>
                    <!-- Resultado importación -->
                    <div id="doc-import-result"
                        class="hidden mt-6 bg-white rounded-2xl border border-slate-200 shadow-sm p-6 w-full">
                        <div class="flex justify-between items-center mb-4">
                            <h4 class="font-bold text-slate-800">Resultado de la importación</h4>
                            <span id="doc-imp-pageinfo" class="text-xs text-slate-500"></span>
                        </div>
                        <div class="grid grid-cols-3 gap-4 mb-5">
                            <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-4 text-center">
                                <p class="text-2xl font-black text-emerald-700" id="doc-imp-inserted">0</p>
                                <p class="text-xs font-bold text-emerald-600 uppercase tracking-wide">Insertados</p>
                            </div>
                            <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-center">
                                <p class="text-2xl font-black text-amber-700" id="doc-imp-updated">0</p>
                                <p class="text-xs font-bold text-amber-600 uppercase tracking-wide">Actualizados</p>
                            </div>
                            <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 text-center">
                                <p class="text-2xl font-black text-slate-700" id="doc-imp-total">0</p>
                                <p class="text-xs font-bold text-slate-600 uppercase tracking-wide">Total filas</p>
                            </div>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead>
                                    <tr class="bg-slate-50 border-b">
                                        <th class="px-3 py-2 text-left text-xs font-black text-slate-500 uppercase">Fila
                                        </th>
                                        <th class="px-3 py-2 text-left text-xs font-black text-slate-500 uppercase">
                                            Apellidos</th>
                                        <th class="px-3 py-2 text-left text-xs font-black text-slate-500 uppercase">
                                            Nombres</th>
                                        <th class="px-3 py-2 text-left text-xs font-black text-slate-500 uppercase">DNI
                                        </th>
                                        <th class="px-3 py-2 text-left text-xs font-black text-slate-500 uppercase">
                                            Razón Social</th>
                                        <th class="px-3 py-2 text-center text-xs font-black text-slate-500 uppercase">
                                            Acción</th>
                                    </tr>
                                </thead>
                                <tbody id="doc-import-preview" class="divide-y divide-slate-100"></tbody>
                            </table>
                        </div>
                        <!-- Paginación -->
                        <div class="mt-4 flex items-center justify-between border-t border-slate-100 pt-4">
                            <span class="text-xs text-slate-500">Mostrando página <span id="doc-imp-pg">1</span> de
                                <span id="doc-imp-pgtotal">1</span></span>
                            <div class="flex gap-2">
                                <button id="doc-imp-prev" onclick="changeImportPage(-1)" disabled
                                    class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white disabled:opacity-50">
                                    <i class="fa-solid fa-chevron-left"></i> Anterior
                                </button>
                                <button id="doc-imp-next" onclick="changeImportPage(1)" disabled
                                    class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white disabled:opacity-50">
                                    Siguiente <i class="fa-solid fa-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tab: Maestra -->
                <div id="doc-tab-maestra" class="hidden">
                    <div
                        class="bg-white p-5 rounded-2xl shadow-sm border border-slate-200 mb-5 flex flex-wrap gap-4 items-end">
                        <div class="flex-1 min-w-[180px]">
                            <label
                                class="block text-xs font-black text-slate-500 mb-1 uppercase tracking-tighter">Buscar</label>
                            <input id="doc-search" type="text" placeholder="Nombre, apellido o DNI..."
                                class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm font-medium focus:ring-2 focus:ring-indigo-500"
                                onkeydown="if(event.key==='Enter') loadMaestra(1)">
                        </div>
                        <div>
                            <label
                                class="block text-xs font-black text-slate-500 mb-1 uppercase tracking-tighter">Estado
                                (Manual)</label>
                            <select id="doc-status-filter" onchange="loadMaestra(1)"
                                class="px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm font-medium focus:ring-2 focus:ring-indigo-500">
                                <option value="">Todos</option>
                                <option value="acts">Solo Activos</option>
                                <option value="inacts">Solo Inactivos</option>
                            </select>
                        </div>
                        <button onclick="loadMaestra(1)"
                            class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2.5 px-6 rounded-xl shadow-md transition-all">
                            <i class="fa-solid fa-filter mr-1"></i> Filtrar
                        </button>
                        <button id="btn-merge-docentes" onclick="openMergeModal()" disabled
                            title="Selecciona exactamente 2 docentes para fusionar"
                            class="bg-amber-500 hover:bg-amber-600 text-white font-bold py-2.5 px-6 rounded-xl shadow-md transition-all disabled:opacity-30 disabled:cursor-not-allowed">
                            <i class="fa-solid fa-code-merge mr-1"></i> Fusionar (0)
                        </button>
                        <button onclick="openTeacherModal()"
                            class="bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-2.5 px-6 rounded-xl shadow-md transition-all">
                            <i class="fa-solid fa-plus mr-1"></i> Nuevo
                        </button>
                    </div>
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm text-left">
                                <thead class="bg-slate-50 border-b border-slate-200">
                                    <tr>
                                        <th class="px-4 py-3 w-10">
                                            <input type="checkbox" disabled class="rounded border-slate-300">
                                        </th>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Apellidos</th>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Nombres</th>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            DNI</th>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Razón Social</th>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter text-center">
                                            Estado</th>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter text-right">
                                            Acciones</th>
                                    </tr>
                                </thead>
                                <tbody id="doc-maestra-body" class="divide-y divide-slate-100"></tbody>
                            </table>
                        </div>
                        <div class="p-5 border-t border-slate-100 flex items-center justify-between bg-slate-50/50">
                            <span class="text-xs text-slate-500">Total: <span id="doc-maestra-total"
                                    class="font-bold text-indigo-600">0</span></span>
                            <div class="flex gap-2">
                                <button id="doc-maestra-prev" onclick="changeMaestraPage(-1)" disabled
                                    class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white disabled:opacity-50">
                                    <i class="fa-solid fa-chevron-left"></i>
                                </button>
                                <span id="doc-maestra-indicator"
                                    class="text-xs font-bold text-slate-700 px-3 py-1.5 bg-white border border-slate-200 rounded-lg">1
                                    / 1</span>
                                <button id="doc-maestra-next" onclick="changeMaestraPage(1)" disabled
                                    class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white disabled:opacity-50">
                                    <i class="fa-solid fa-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tab: Sin Asignar -->
                <div id="doc-tab-sinasignar" class="hidden">
                    <div class="flex justify-between items-center mb-4">
                        <p class="text-sm text-slate-500">Ordenados por frecuencia (más críticos primero). Origen: XML o
                            Observación.</p>
                        <button onclick="runReprocesarHistorico()"
                            class="bg-amber-500 hover:bg-amber-600 text-white font-bold py-2 px-5 rounded-xl text-sm shadow-md transition-all">
                            <i class="fa-solid fa-arrows-rotate mr-1"></i> Reprocesar Histórico
                        </button>
                    </div>
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm text-left">
                                <thead class="bg-slate-50 border-b border-slate-200">
                                    <tr>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Apellidos</th>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Nombres</th>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            DNI</th>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Razón Social</th>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter text-center">
                                            Origen</th>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter text-center">
                                            Detecciones</th>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Último visto</th>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter text-right">
                                            Acciones</th>
                                    </tr>
                                </thead>
                                <tbody id="doc-sinasignar-body" class="divide-y divide-slate-100"></tbody>
                            </table>
                        </div>
                        <div class="p-5 border-t border-slate-100 flex items-center justify-between bg-slate-50/50">
                            <span class="text-xs text-slate-500">Total: <span id="doc-sinasignar-total"
                                    class="font-bold text-amber-600">0</span></span>
                            <div class="flex gap-2">
                                <button id="doc-sa-prev" onclick="changeSinAsignarPage(-1)" disabled
                                    class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white disabled:opacity-50">
                                    <i class="fa-solid fa-chevron-left"></i>
                                </button>
                                <span id="doc-sa-indicator"
                                    class="text-xs font-bold text-slate-700 px-3 py-1.5 bg-white border border-slate-200 rounded-lg">1
                                    / 1</span>
                                <button id="doc-sa-next" onclick="changeSinAsignarPage(1)" disabled
                                    class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white disabled:opacity-50">
                                    <i class="fa-solid fa-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tab: Conflictos Fuzzy -->
                <div id="doc-tab-conflictos" class="hidden">
                    <div class="flex justify-between items-center mb-4">
                        <p class="text-sm text-slate-500">Coincidencias aproximadas (&ge;90%) entre docentes XML y la
                            maestra. Requieren validación humana.</p>
                        <button onclick="runReprocesarHistorico()"
                            class="bg-rose-500 hover:bg-rose-600 text-white font-bold py-2 px-5 rounded-xl text-sm shadow-md transition-all">
                            <i class="fa-solid fa-rotate mr-1"></i> Actualizar análisis
                        </button>
                    </div>
                    <div id="conflictos-empty"
                        class="hidden bg-emerald-50 border border-emerald-200 rounded-2xl p-8 text-center">
                        <i class="fa-solid fa-circle-check text-emerald-500 text-3xl mb-3 block"></i>
                        <p class="font-bold text-emerald-800">Sin conflictos detectados</p>
                        <p class="text-sm text-emerald-600 mt-1">Todos los docentes XML están correctamente vinculados a
                            la maestra.</p>
                    </div>
                    <div id="conflictos-info"
                        class="hidden mb-4 bg-rose-50 border border-rose-200 rounded-xl p-4 text-sm text-rose-800">
                        <i class="fa-solid fa-triangle-exclamation mr-1"></i>
                        <span id="conflictos-count-msg"></span>
                    </div>
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm text-left">
                                <thead class="bg-slate-50 border-b border-slate-200">
                                    <tr>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Detectado (XML)</th>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                            Sugerido (Maestra)</th>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter text-center">
                                            Similitud</th>
                                        <th
                                            class="px-4 py-3 text-xs font-black text-slate-500 uppercase tracking-tighter text-right">
                                            Decisión</th>
                                    </tr>
                                </thead>
                                <tbody id="doc-conflictos-body" class="divide-y divide-slate-100">
                                    <tr>
                                        <td colspan="4" class="px-4 py-10 text-center text-slate-400">Ejecuta
                                            "Actualizar análisis" para ver los conflictos.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Modal: Fusionar Docentes -->
            <div id="merge-modal"
                class="hidden fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[60] flex items-center justify-center p-4">
                <div
                    class="bg-white rounded-3xl shadow-2xl w-full max-w-4xl max-h-[90vh] overflow-hidden flex flex-col scale-in">
                    <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                        <div>
                            <h3 class="text-xl font-black text-slate-900 uppercase tracking-tight">Fusión de Docentes
                            </h3>
                            <p class="text-xs text-slate-500 font-bold uppercase tracking-widest mt-1">Consolidación de
                                registros duplicados</p>
                        </div>
                        <button onclick="closeMergeModal()"
                            class="text-slate-400 hover:text-slate-600 transition-colors">
                            <i class="fa-solid fa-xmark text-xl"></i>
                        </button>
                    </div>
                    <div class="p-8 overflow-y-auto">
                        <div class="bg-amber-50 border border-amber-200 rounded-2xl p-4 mb-8 flex gap-4 items-start">
                            <div
                                class="w-10 h-10 bg-amber-100 text-amber-600 rounded-full flex items-center justify-center shrink-0">
                                <i class="fa-solid fa-triangle-exclamation text-lg"></i>
                            </div>
                            <div>
                                <p class="text-sm font-bold text-amber-900">Advertencia de Fusión</p>
                                <p class="text-xs text-amber-800 mt-1 leading-relaxed">
                                    Esta operación es irreversible. Todas las lecciones y observaciones del docente
                                    <b>secundario</b> se transferirán al <b>principal</b>. El registro secundario será
                                    eliminado permanentemente de la base de datos.
                                </p>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-8 relative">
                            <!-- Divider visual -->
                            <div
                                class="absolute left-1/2 top-0 bottom-0 w-px bg-slate-100 -translate-x-1/2 hidden md:block">
                            </div>

                            <!-- Docente 1 -->
                            <div id="merge-card-0"
                                class="p-6 rounded-2xl border-2 border-slate-100 transition-all cursor-pointer relative"
                                onclick="selectPrincipal(0)">
                                <div class="absolute top-4 right-4">
                                    <input type="radio" name="principal-choice" id="radio-p-0"
                                        class="w-5 h-5 text-indigo-600 focus:ring-indigo-500 border-slate-300">
                                </div>
                                <span
                                    class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 block">Candidato
                                    A</span>
                                <h4 id="merge-name-0" class="text-lg font-black text-slate-900 mb-4">—</h4>
                                <div class="space-y-3">
                                    <div>
                                        <label class="text-[10px] font-black text-slate-400 uppercase">DNI</label>
                                        <p id="merge-dni-0" class="text-sm font-mono font-bold text-slate-700">—</p>
                                    </div>
                                    <div>
                                        <label class="text-[10px] font-black text-slate-400 uppercase">Razón
                                            Social</label>
                                        <p id="merge-rs-0" class="text-sm font-bold text-slate-700">—</p>
                                    </div>
                                    <div id="merge-badge-0"></div>
                                </div>
                            </div>

                            <!-- Docente 2 -->
                            <div id="merge-card-1"
                                class="p-6 rounded-2xl border-2 border-slate-100 transition-all cursor-pointer relative"
                                onclick="selectPrincipal(1)">
                                <div class="absolute top-4 right-4">
                                    <input type="radio" name="principal-choice" id="radio-p-1"
                                        class="w-5 h-5 text-indigo-600 focus:ring-indigo-500 border-slate-300">
                                </div>
                                <span
                                    class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 block">Candidato
                                    B</span>
                                <h4 id="merge-name-1" class="text-lg font-black text-slate-900 mb-4">—</h4>
                                <div class="space-y-3">
                                    <div>
                                        <label class="text-[10px] font-black text-slate-400 uppercase">DNI</label>
                                        <p id="merge-dni-1" class="text-sm font-mono font-bold text-slate-700">—</p>
                                    </div>
                                    <div>
                                        <label class="text-[10px] font-black text-slate-400 uppercase">Razón
                                            Social</label>
                                        <p id="merge-rs-1" class="text-sm font-bold text-slate-700">—</p>
                                    </div>
                                    <div id="merge-badge-1"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="p-6 bg-slate-50 border-t border-slate-100 flex justify-end gap-3">
                        <button onclick="closeMergeModal()"
                            class="px-6 py-2.5 text-sm font-bold text-slate-600 hover:text-slate-800 transition-colors">Cancelar</button>
                        <button id="btn-confirm-merge" onclick="executeMerge()" disabled
                            class="bg-indigo-600 hover:bg-indigo-700 text-white font-black py-2.5 px-8 rounded-xl shadow-lg shadow-indigo-600/20 transition-all disabled:opacity-50">
                            CONFIRMAR FUSIÓN
                        </button>
                    </div>
                </div>
            </div>

            <!-- Modal: Editar / Crear Docente Maestra -->
            <div id="teacher-modal"
                class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
                <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden">
                    <div class="p-6 border-b border-slate-100 flex justify-between items-center">
                        <h3 id="teacher-modal-title" class="text-xl font-black text-slate-800">Docente</h3>
                        <button onclick="closeTeacherModal()"
                            class="text-slate-400 hover:text-rose-500 transition-colors">
                            <i class="fa-solid fa-xmark text-xl"></i>
                        </button>
                    </div>
                    <div class="p-6 space-y-4">
                        <input type="hidden" id="teacher-modal-id">
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label
                                    class="block text-xs font-black text-slate-500 mb-1 uppercase tracking-tighter">Apellidos
                                    *</label>
                                <input id="teacher-modal-lastname" type="text"
                                    class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500"
                                    placeholder="PÉREZ GOMEZ">
                            </div>
                            <div>
                                <label
                                    class="block text-xs font-black text-slate-500 mb-1 uppercase tracking-tighter">Nombres
                                    *</label>
                                <input id="teacher-modal-firstname" type="text"
                                    class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500"
                                    placeholder="JUAN CARLOS">
                            </div>
                        </div>
                        <div>
                            <label
                                class="block text-xs font-black text-slate-500 mb-1 uppercase tracking-tighter">DNI</label>
                            <input id="teacher-modal-dni" type="text" maxlength="15"
                                class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500"
                                placeholder="12345678">
                        </div>
                        <div>
                            <label class="block text-xs font-black text-slate-500 mb-1 uppercase tracking-tighter">Razón
                                Social</label>
                            <input id="teacher-modal-razon" type="text"
                                class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500"
                                placeholder="Empresa S.A.C.">
                        </div>
                    </div>
                    <div class="p-6 pt-0 flex gap-3">
                        <button onclick="saveTeacher()"
                            class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 rounded-xl transition-all">
                            <i class="fa-solid fa-floppy-disk mr-1"></i> Guardar
                        </button>
                        <button onclick="closeTeacherModal()"
                            class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold py-3 rounded-xl transition-all">Cancelar</button>
                    </div>
                </div>
            </div>

            <!-- Modal: Editar Sin Asignar -->
            <div id="sinasignar-modal"
                class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
                <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden">
                    <div class="p-6 border-b border-slate-100 flex justify-between items-center">
                        <h3 class="text-xl font-black text-slate-800">Editar Docente Sin Asignar</h3>
                        <button onclick="closeSinAsignarModal()"
                            class="text-slate-400 hover:text-rose-500 transition-colors">
                            <i class="fa-solid fa-xmark text-xl"></i>
                        </button>
                    </div>
                    <div class="p-6 space-y-4">
                        <input type="hidden" id="sinasignar-modal-id">
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label
                                    class="block text-xs font-black text-slate-500 mb-1 uppercase tracking-tighter">Apellidos</label>
                                <input id="sa-modal-apellidos" type="text"
                                    class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500">
                            </div>
                            <div>
                                <label
                                    class="block text-xs font-black text-slate-500 mb-1 uppercase tracking-tighter">Nombres</label>
                                <input id="sa-modal-nombres" type="text"
                                    class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500">
                            </div>
                        </div>
                        <div>
                            <label
                                class="block text-xs font-black text-slate-500 mb-1 uppercase tracking-tighter">DNI</label>
                            <input id="sa-modal-dni" type="text" maxlength="15"
                                class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500">
                        </div>
                        <div>
                            <label class="block text-xs font-black text-slate-500 mb-1 uppercase tracking-tighter">Razón
                                Social</label>
                            <input id="sa-modal-razon" type="text"
                                class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500">
                        </div>
                    </div>
                    <div class="p-6 pt-0 flex gap-3">
                        <button onclick="saveSinAsignar()"
                            class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 rounded-xl transition-all">
                            <i class="fa-solid fa-floppy-disk mr-1"></i> Guardar
                        </button>
                        <button onclick="promoteSinAsignar()"
                            class="flex-1 bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 rounded-xl transition-all">
                            <i class="fa-solid fa-arrow-up-from-bracket mr-1"></i> Promover a Maestra
                        </button>
                    </div>
                </div>
            </div>

            <!-- Modal: Confirmar Cambio de Estado (v3.10) -->
            <div id="teacher-status-modal"
                class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[70] hidden flex items-center justify-center p-4">
                <div
                    class="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden animate-in fade-in zoom-in duration-300">
                    <div class="p-10 text-center">
                        <div id="status-modal-icon"
                            class="w-24 h-24 mx-auto rounded-full flex items-center justify-center mb-8 text-4xl shadow-lg border-4 border-white">
                            <i class="fa-solid fa-power-off"></i>
                        </div>
                        <h3 id="status-modal-title"
                            class="text-2xl font-black text-slate-900 mb-2 uppercase tracking-tight">¿Confirmar cambio?
                        </h3>
                        <p id="status-modal-msg" class="text-slate-500 font-bold mb-8 leading-relaxed text-sm px-4">
                            ¿Deseas cambiar el estado de este docente?</p>

                        <!-- Advertencia de Actividad -->
                        <div id="status-activity-warning"
                            class="hidden bg-rose-50 border border-rose-200 rounded-2xl p-5 mb-8 text-left flex gap-4 animate-in fade-in slide-in-from-bottom-4 duration-500 shadow-sm">
                            <div class="w-8 h-8 rounded-full bg-rose-100 flex items-center justify-center shrink-0">
                                <i class="fa-solid fa-triangle-exclamation text-rose-500"></i>
                            </div>
                            <p class="text-xs font-black text-rose-800 leading-tight uppercase tracking-tighter">
                                Este docente tiene actividad registrada (lecciones o reemplazos).
                                Al desactivarlo, dejará de aparecer en el RPT Planilla.
                            </p>
                        </div>

                        <div class="flex flex-col gap-3">
                            <button onclick="confirmStatusChange()" id="btn-status-confirm"
                                class="w-full bg-slate-900 hover:bg-black text-white font-black py-4 rounded-2xl transition-all shadow-xl active:scale-95 uppercase tracking-widest text-xs">
                                SÍ, CONFIRMAR CAMBIO
                            </button>
                            <button onclick="closeStatusModal()"
                                class="w-full bg-slate-100 hover:bg-slate-200 text-slate-500 font-extrabold py-4 rounded-2xl transition-all uppercase tracking-widest text-xs">
                                VOLVER
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recess Configuration Section -->
            <div id="recess-config" class="section max-w-7xl mx-auto">
                <div class="flex justify-between items-center mb-8">
                    <div>
                        <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">Configuración de Recesos</h2>
                        <p class="text-slate-500 mt-2">Gestiona los tiempos de descanso intermedios.</p>
                    </div>
                    <button onclick="openConfigModal('recess')"
                        class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-xl shadow-lg shadow-indigo-600/20 font-bold flex items-center gap-2 transition-all transform hover:-translate-y-0.5">
                        <i class="fa-solid fa-plus text-lg"></i> Agregar Receso
                    </button>
                </div>

                <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 border-b border-slate-200">
                                <th class="px-6 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                    Nombre
                                </th>
                                <th class="px-6 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">Hora
                                    Inicio</th>
                                <th class="px-6 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">Hora
                                    Fin
                                </th>
                                <th
                                    class="px-6 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter text-center">
                                    Duración</th>
                                <th
                                    class="px-6 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter text-right">
                                    Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="recess-config-body" class="divide-y divide-slate-100 italic text-slate-400">
                            <!-- Carga dinámica -->
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Lunch Configuration Section -->
            <div id="lunch-config" class="section max-w-7xl mx-auto">
                <div class="flex justify-between items-center mb-8">
                    <div>
                        <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">Configuración de Almuerzos
                        </h2>
                        <p class="text-slate-500 mt-2">Gestiona los tiempos extendidos para alimentación.</p>
                    </div>
                    <button onclick="openConfigModal('lunch')"
                        class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-xl shadow-lg shadow-indigo-600/20 font-bold flex items-center gap-2 transition-all transform hover:-translate-y-0.5">
                        <i class="fa-solid fa-plus text-lg"></i> Agregar Almuerzo
                    </button>
                </div>

                <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 border-b border-slate-200">
                                <th class="px-6 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">
                                    Nombre
                                </th>
                                <th class="px-6 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">Hora
                                    Inicio</th>
                                <th class="px-6 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">Hora
                                    Fin
                                </th>
                                <th
                                    class="px-6 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter text-center">
                                    Duración</th>
                                <th
                                    class="px-6 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter text-right">
                                    Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="lunch-config-body" class="divide-y divide-slate-100 italic text-slate-400">
                            <!-- Carga dinámica -->
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Modal Configuración -->
            <div id="config-modal"
                class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
                <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden transform transition-all">
                    <div class="p-8 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                        <h3 id="config-modal-title" class="text-2xl font-black text-slate-800 tracking-tight">Agregar
                            Configuración</h3>
                        <button onclick="closeConfigModal()"
                            class="text-slate-400 hover:text-rose-500 transition-colors"><i
                                class="fa-solid fa-xmark text-xl"></i></button>
                    </div>
                    <div class="p-8 space-y-6">
                        <input type="hidden" id="config-id">
                        <input type="hidden" id="config-type">

                        <div>
                            <label
                                class="block text-xs font-black text-slate-500 mb-2 uppercase tracking-tighter">Nombre
                                descriptivo</label>
                            <input type="text" id="config-name" placeholder="Ej: Receso Mañana"
                                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-medium text-slate-700 transition-all">
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label
                                    class="block text-xs font-black text-slate-500 mb-2 uppercase tracking-tighter">Hora
                                    Inicio</label>
                                <input type="time" id="config-start" onchange="calculateDuration()"
                                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-medium text-slate-700 transition-all">
                            </div>
                            <div>
                                <label
                                    class="block text-xs font-black text-slate-500 mb-2 uppercase tracking-tighter">Hora
                                    Fin</label>
                                <input type="time" id="config-end" onchange="calculateDuration()"
                                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-medium text-slate-700 transition-all">
                            </div>
                        </div>

                        <div
                            class="bg-indigo-50 p-4 rounded-xl border border-indigo-100 flex items-center justify-between">
                            <span class="text-xs font-bold text-indigo-700 uppercase tracking-widest">Duración
                                estimada</span>
                            <span id="config-duration" class="font-black text-indigo-800">0 min</span>
                        </div>

                        <button onclick="saveConfig()"
                            class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-black py-4 rounded-2xl shadow-lg shadow-indigo-600/30 transition-all transform hover:-translate-y-1 active:scale-[0.98]">
                            Guardar Configuración
                        </button>
                    </div>
                </div>
            </div>
            <!-- Modal: Registrar Observación -->
            <div id="obs-register-modal"
                class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[60] hidden flex items-center justify-center p-4">
                <div
                    class="bg-white rounded-3xl shadow-2xl w-full max-w-lg overflow-hidden transform transition-all animate-in zoom-in duration-300">
                    <div class="p-8 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                        <h3 class="text-2xl font-black text-slate-800 tracking-tight">Registrar Incidencia</h3>
                        <button onclick="closeObsRegisterModal()"
                            class="text-slate-400 hover:text-rose-500 transition-colors"><i
                                class="fa-solid fa-xmark text-xl"></i></button>
                    </div>
                    <div class="p-8 space-y-6">
                        <input type="hidden" id="obs-form-session-id">
                        <input type="hidden" id="obs-form-teacher-id">

                        <div class="grid grid-cols-2 gap-4 bg-indigo-50 p-4 rounded-xl border border-indigo-100">
                            <div>
                                <p
                                    class="text-[10px] font-black text-indigo-400 uppercase tracking-widest leading-none mb-1">
                                    Docente Afectado</p>
                                <p id="obs-modal-teacher-name" class="font-bold text-slate-800 text-sm">---</p>
                            </div>
                            <div>
                                <p
                                    class="text-[10px] font-black text-indigo-400 uppercase tracking-widest leading-none mb-1">
                                    Fecha de Clase</p>
                                <p id="obs-modal-date" class="font-bold text-slate-800 text-sm">---</p>
                            </div>
                        </div>

                        <!-- Toggle Desglose -->
                        <div class="bg-slate-50 p-4 rounded-xl border border-slate-200">
                            <label
                                class="block text-xs font-black text-slate-500 mb-3 uppercase tracking-tighter">¿Aplicar
                                incidencia a todo el bloque?</label>
                            <div class="flex gap-6">
                                <label class="flex items-center gap-2 cursor-pointer group">
                                    <input type="radio" name="obs-block-mode" value="full" checked
                                        onchange="toggleObsBlockMode(true)"
                                        class="w-4 h-4 text-indigo-600 focus:ring-indigo-500">
                                    <span
                                        class="text-sm font-bold text-slate-700 group-hover:text-indigo-600 transition-colors">Sí,
                                        todo el bloque</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer group">
                                    <input type="radio" name="obs-block-mode" value="split"
                                        onchange="toggleObsBlockMode(false)"
                                        class="w-4 h-4 text-indigo-600 focus:ring-indigo-500">
                                    <span
                                        class="text-sm font-bold text-slate-700 group-hover:text-indigo-600 transition-colors">No,
                                        desglosar por horas (50m)</span>
                                </label>
                            </div>
                        </div>

                        <!-- Single Mode Container -->
                        <div id="obs-single-mode-container" class="space-y-6">

                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label
                                        class="block text-xs font-black text-slate-500 mb-2 uppercase tracking-tighter">Tipo
                                        de Incidencia</label>
                                    <select id="obs-form-type" onchange="handleObsTypeChange()"
                                        class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 font-medium text-slate-700 text-sm">
                                        <option value="FALTA">FALTA</option>
                                        <option value="REEMPLAZO">REEMPLAZO</option>
                                    </select>
                                </div>
                                <div>
                                    <label
                                        class="block text-xs font-black text-slate-500 mb-2 uppercase tracking-tighter">Tipo
                                        de Descuento</label>
                                    <select id="obs-form-discount"
                                        class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 font-medium text-slate-700 text-sm">
                                        <option value="SIMPLE">SIMPLE</option>
                                        <option value="DOBLE">DOBLE</option>
                                        <option value="TRIPLE">TRIPLE</option>
                                    </select>
                                </div>
                            </div>

                            <div id="obs-replacement-container"
                                class="hidden animate-in fade-in slide-in-from-top-2 duration-300">
                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <label
                                            class="block text-[10px] font-black text-slate-400 mb-1 uppercase tracking-widest">Apellidos
                                            del Docente</label>
                                        <input type="text" id="obs-form-replacement-last" list="teachers-datalist"
                                            placeholder="Ej: MOSTACERO..."
                                            class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 font-medium text-slate-700 text-sm shadow-sm transition-all focus:bg-white">
                                    </div>
                                    <div>
                                        <label
                                            class="block text-[10px] font-black text-slate-400 mb-1 uppercase tracking-widest">Nombres
                                            del Docente</label>
                                        <input type="text" id="obs-form-replacement-first" placeholder="Ej: JORDY..."
                                            class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 font-medium text-slate-700 text-sm shadow-sm transition-all focus:bg-white">
                                    </div>
                                </div>
                                <datalist id="teachers-datalist"></datalist>
                            </div>

                            <div>
                                <label
                                    class="block text-xs font-black text-slate-500 mb-2 uppercase tracking-tighter">Observación
                                    / Justificación</label>
                                <textarea id="obs-form-description" rows="3"
                                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 font-medium text-slate-700 text-sm"
                                    placeholder="Detalle el motivo de la incidencia..."></textarea>
                            </div>
                        </div>

                        <!-- Split Mode Container (Dynamic) -->
                        <div id="obs-split-mode-container"
                            class="hidden space-y-4 max-h-[40vh] overflow-y-auto pr-2 custom-scrollbar">
                            <!-- Dynamic slots go here -->
                        </div>

                        <button onclick="saveObservation()"
                            class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-black py-4 rounded-2xl shadow-lg shadow-indigo-600/30 transition-all transform hover:-translate-y-1 active:scale-[0.98]">
                            Confirmar y Registrar
                        </button>
                    </div>
                </div>
            </div>

            <!-- Modal: Confirmación -->
            <div id="obs-confirm-modal"
                class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[70] hidden flex items-center justify-center p-4">
                <div
                    class="bg-white rounded-3xl shadow-2xl max-w-sm w-full overflow-hidden animate-in zoom-in duration-300">
                    <div class="p-8 text-center">
                        <div
                            class="w-20 h-20 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-6">
                            <i class="fa-solid fa-check text-3xl"></i>
                        </div>
                        <h3 class="text-2xl font-black text-slate-900 mb-2">¡Registro Exitoso!</h3>
                        <p class="text-slate-500 text-sm mb-8 leading-relaxed">La incidencia ha sido registrada
                            correctamente. El cambio se verá reflejado en el reporte de planillas.</p>
                        <button onclick="closeObsConfirmModal()"
                            class="w-full bg-slate-800 hover:bg-slate-900 text-white font-black py-4 rounded-2xl transition-all">Entendido</button>
                    </div>
                </div>
            </div>

            <!-- =================================================================
             MÓDULO DE USUARIOS
        ================================================================== -->
            <div id="usuarios-module" class="section max-w-7xl mx-auto">
                <div class="mb-8">
                    <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">Administración de Seguridad</h2>
                    <p class="text-slate-50 mt-2 text-slate-500">Gestión de usuarios, roles y matriz de permisos RBAC.</p>
                </div>

                <!-- Sub-tabs Usuarios -->
                <div class="flex border-b border-slate-200 mb-8 overflow-x-auto">
                    <button onclick="toggleUsuariosTab('list')" id="usr-tab-btn-list"
                        class="usr-tab-btn px-8 py-4 text-sm font-black border-b-2 border-indigo-600 text-indigo-600 transition-all uppercase tracking-widest whitespace-nowrap">
                        <i class="fa-solid fa-users-gear mr-2"></i>Lista de Usuarios
                    </button>
                    <button onclick="toggleUsuariosTab('rbac')" id="usr-tab-btn-rbac"
                        class="usr-tab-btn px-8 py-4 text-sm font-black border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all uppercase tracking-widest whitespace-nowrap">
                        <i class="fa-solid fa-shield-halved mr-2"></i>Permisos por Rol
                    </button>
                </div>

                <!-- TAB: Lista de Usuarios -->
                <div id="usr-tab-list">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="text-lg font-bold text-slate-800">Cuentas de Usuario</h3>
                        <button onclick="openUsuarioModal()"
                            class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2.5 px-6 rounded-xl shadow-md transition-all flex items-center gap-2">
                            <i class="fa-solid fa-user-plus"></i> Nuevo Usuario
                        </button>
                    </div>

                    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm text-left">
                                <thead class="bg-slate-50 border-b border-slate-200">
                                    <tr>
                                        <th class="px-5 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">Colaborador</th>
                                        <th class="px-5 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">Cuenta / Email</th>
                                        <th class="px-5 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">Roles</th>
                                        <th class="px-5 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter">Estado</th>
                                        <th class="px-5 py-4 text-xs font-black text-slate-500 uppercase tracking-tighter text-right">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody id="usuarios-tbody" class="divide-y divide-slate-100">
                                    <tr><td colspan="5" class="px-5 py-12 text-center text-slate-400">Cargando usuarios...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- TAB: RBAC Matrix -->
                <div id="usr-tab-rbac" class="hidden">
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                        <div class="p-6 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
                            <div>
                                <h3 class="text-lg font-bold text-slate-800">Matriz de Permisos</h3>
                                <p class="text-xs text-slate-500 font-medium">Asigna permisos granulares a cada rol del sistema.</p>
                            </div>
                            <button onclick="saveRolePermissions()" id="btn-save-rbac" class="bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-2 px-6 rounded-xl shadow-md transition-all">
                                <i class="fa-solid fa-floppy-disk mr-2"></i>Guardar Matriz
                            </button>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm text-left border-collapse">
                                <thead id="rbac-thead" class="bg-slate-50 border-b border-slate-200">
                                    <!-- Dynamic Roles Header -->
                                </thead>
                                <tbody id="rbac-tbody" class="divide-y divide-slate-100">
                                    <!-- Dynamic Permissions Rows -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Modal Nuevo/Editar Usuario -->
                <div id="usuario-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm">
                    <div class="bg-white rounded-2xl shadow-2xl max-w-lg w-full overflow-hidden flex flex-col max-h-[90vh]">
                        <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50 text-slate-900">
                            <h3 id="usuario-modal-title" class="text-xl font-bold">Configurar Acceso</h3>
                            <button onclick="closeUsuarioModal()" class="text-slate-400 hover:text-slate-600"><i class="fa-solid fa-xmark text-xl"></i></button>
                        </div>
                        <form id="usuario-form" class="p-6 overflow-y-auto">
                            <input type="hidden" id="usr-id">
                            <div class="grid grid-cols-2 gap-4 mb-4">
                                <div>
                                    <label class="block text-xs font-black text-slate-500 mb-1 uppercase tracking-wide">Nombres</label>
                                    <input type="text" id="usr-nombres" required class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-700 focus:border-indigo-500">
                                </div>
                                <div>
                                    <label class="block text-xs font-black text-slate-500 mb-1 uppercase tracking-wide">Apellidos</label>
                                    <input type="text" id="usr-apellidos" required class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-700 focus:border-indigo-500">
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="block text-xs font-black text-slate-500 mb-1 uppercase tracking-wide">Correo Institucional</label>
                                <input type="email" id="usr-email" placeholder="@vonex.edu.pe" required pattern=".*@vonex\.edu\.pe" class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-700 focus:border-indigo-500">
                            </div>
                            <div class="mb-4" id="usr-pwd-container">
                                <label class="block text-xs font-black text-slate-500 mb-1 uppercase tracking-wide">Contraseña Provisional</label>
                                <input type="password" id="usr-password" minlength="6" class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-700 focus:border-indigo-500">
                                <p class="text-[10px] text-slate-400 mt-1">Requerido para cuentas nuevas (mín 6 caracts).</p>
                            </div>
                            <div class="mb-6">
                                <label class="block text-xs font-black text-slate-500 mb-1 uppercase tracking-wide">Área Operativa</label>
                                <input type="text" id="usr-area" class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-700 focus:border-indigo-500">
                            </div>
                            <div class="border-t border-slate-200 pt-4">
                                <label class="block text-xs font-black text-slate-800 mb-3 uppercase tracking-wider">Asignación de Roles</label>
                                <div id="usr-roles-container" class="grid grid-cols-2 gap-3"></div>
                            </div>
                            <div class="mt-8 flex gap-3">
                                <button type="submit" id="usr-save-btn" class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 rounded-xl transition-all shadow-lg shadow-indigo-600/20">Guardar Credenciales</button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Modal: Reset Password (Admin) -->
                <div id="reset-pwd-modal" class="hidden fixed inset-0 z-[60] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm">
                    <div class="bg-white rounded-2xl shadow-2xl max-w-sm w-full overflow-hidden animate-in zoom-in duration-200">
                        <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50">
                            <h3 class="text-lg font-bold text-slate-900">Resetear Contraseña</h3>
                            <button onclick="closeResetPwdModal()" class="text-slate-400 hover:text-slate-600"><i class="fa-solid fa-xmark text-xl"></i></button>
                        </div>
                        <div class="p-6">
                            <p class="text-xs text-slate-500 mb-4 font-medium uppercase tracking-wider">Usuario: <span id="reset-pwd-user" class="font-black text-slate-800"></span></p>
                            <label class="block text-xs font-black text-slate-500 mb-1 uppercase tracking-wide">Nueva Contraseña</label>
                            <input type="password" id="new-pwd-input" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl mb-6 focus:border-indigo-500 outline-none transition-all">
                            <button onclick="confirmResetPassword()" id="btn-confirm-reset-pwd" class="w-full bg-rose-600 hover:bg-rose-700 text-white font-black py-4 rounded-xl shadow-lg shadow-rose-600/20 transition-all uppercase tracking-widest text-xs">
                                ACTUALIZAR CONTRASEÑA
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        </main>

        <script>

            // ==========================================
            // MÓDULO 1: CONFIGURACIÓN GLOBAL
            // ==========================================
            (function (global) {
                global.window = global;
                window.CONFIG = {
                    BASE_URL: 'http://localhost:8000',
                    API_DOC: 'http://127.0.0.1:8000/api/docentes'
                };
            })(window);

            // ==========================================
            // MÓDULO 2: AUTH JWT
            // ==========================================
            (function (global) {
                function getToken() { return localStorage.getItem('access_token'); }
                function setToken(token) { localStorage.setItem('access_token', token); }

                function parseJwt(token) {
                    try {
                        const base64Url = token.split('.')[1];
                        const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                        const jsonPayload = decodeURIComponent(window.atob(base64).split('').map(function (c) {
                            return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                        }).join(''));
                        return JSON.parse(jsonPayload);
                    } catch (e) { console.error("JWT Parse Error", e); return {}; }
                }

                function hasPermission(permission) {
                    const token = getToken();
                    if (!token) return false;
                    const payload = parseJwt(token);
                    // Los permisos vienen en el payload del JWT (según backend)
                    return payload.permissions?.includes(permission);
                }

                const nativeFetch = window.fetch;

                async function authFetch(url, options = {}) {
                    const token = getToken();
                    if (!options.headers) options.headers = {};

                    if (url.includes('/api/users/login')) {
                        return nativeFetch(url, options);
                    }

                    if (token) {
                        options.headers['Authorization'] = `Bearer ${token}`;
                    }

                    const res = await nativeFetch(url, options);

                    if (res.status === 401) {
                        console.warn("⛔ Session Expired (401)");
                        global.logout();
                        throw new Error("Sesión expirada");
                    }

                    if (res.status === 403) {
                        const errData = await res.json().catch(() => ({}));
                        const msg = errData.detail || "No tienes permisos para realizar esta acción (403)";
                        console.warn("🚫 Permiso Denegado:", msg);
                        alert(msg); // 🔴 AJUSTE: Alert pero NO logout
                        throw new Error(msg);
                    }

                    return res;
                }

                function logout() {
                    localStorage.removeItem('access_token');
                    global.currentUserContext = null;
                    if (global.showLogin) global.showLogin();
                    // Limpiar UI
                    location.reload(); 
                }

                // Expose
                global.getToken = getToken;
                global.setToken = setToken;
                global.parseJwt = parseJwt;
                global.hasPermission = hasPermission;
                global.authFetch = authFetch;
                global.logout = logout;
            })(window);

            // ==========================================
            // MÓDULO 3: APP CORE & NAVEGACIÓN
            // ==========================================
            (function (global) {
                global.currentUserContext = null;

                async function initApp() {
                    const token = global.getToken();
                    if (!token) {
                        showLogin();
                        return;
                    }

                    try {
                        const res = await global.authFetch(window.CONFIG.BASE_URL + '/api/users/me');
                        if (!res.ok) throw new Error("Token Inválido");

                        global.currentUserContext = await res.json();

                        document.getElementById('current-username-display').innerText = global.currentUserContext.username;
                        console.log("✅ Sesión validada. Bienvenid@ " + global.currentUserContext.username);

                        showApp();
                        if (window.applyRBAC) window.applyRBAC();

                        // DEFERRED DATA LOADS (GLOBAL SCOPE FIX)
                        console.log("🚀 Sesión validada. Iniciando Cargas Maestras...");
                        if (window.loadRptCatalogs) await window.loadRptCatalogs();
                        if (window.loadCatalogs) await window.loadCatalogs();
                        if (window.loadObsLogs) await window.loadObsLogs();
                        if (window.loadUploadHistory) window.loadUploadHistory();
                        if (window.setInitialDates) window.setInitialDates();

                    } catch (e) {

                        console.warn("⚠️ Fallo en InitApp:", e.message);
                        global.logout();
                    }
                }

                function showLogin() {
                    const app = document.getElementById('app-container');
                    const login = document.getElementById('login-container');
                    if (app) app.style.display = 'none';
                    if (login) login.style.display = 'flex';
                }

                function showApp() {
                    const app = document.getElementById('app-container');
                    const login = document.getElementById('login-container');
                    if (login) login.style.display = 'none';
                    if (app) app.style.display = 'flex';
                }

                function nav(sectionId) {
                    document.querySelectorAll('.nav-btn').forEach(btn => {
                        btn.classList.remove('bg-indigo-600', 'text-white', 'shadow-md', 'shadow-indigo-900/50');
                        if (!btn.classList.contains('text-slate-300')) {
                            btn.classList.add('text-slate-300', 'hover:bg-slate-800');
                        }
                    });

                    const activeBtn = Array.from(document.querySelectorAll('.nav-btn')).find(b => b.getAttribute('onclick') === "nav('" + sectionId + "')");
                    if (activeBtn) {
                        activeBtn.classList.add('bg-indigo-600', 'text-white', 'shadow-md', 'shadow-indigo-900/50');
                        activeBtn.classList.remove('text-slate-300', 'hover:bg-slate-800');
                    }

                    document.querySelectorAll('.section').forEach(el => el.classList.remove('active'));
                    const targetSection = document.getElementById(sectionId);
                    if (targetSection) {
                        targetSection.classList.add('active');
                        // RBAC Guard for manual nav attempts
                        if (sectionId === 'usuarios-module' && !global.hasPermission('gestionar_usuarios')) {
                            global.nav('schedule');
                            return;
                        }
                        if (sectionId === 'usuarios-module' && global.loadUsuarios) global.loadUsuarios();
                    }
                }

                // Expose
                global.initApp = initApp;
                global.showLogin = showLogin;
                global.showApp = showApp;
                global.nav = nav;
            })(window);

            // ==========================================
            // MÓDULO 4: RBAC SECURITY
            // ==========================================
            (function (global) {
                function applyRBAC() {
                    if (!global.currentUserContext) return;
                    
                    const perms = {
                        upload: global.hasPermission("subir_xml"),
                        horarios: global.hasPermission("ver_horarios"),
                        obs: global.hasPermission("ver_observaciones"),
                        rpt: global.hasPermission("ver_rpt"),
                        docentes: global.hasPermission("ver_docentes"),
                        usuarios: global.hasPermission("gestionar_usuarios"),
                        config: global.hasPermission("gestionar_configuracion")
                    };

                    console.log("🛂 Aplicando RBAC Matrix:", perms);

                    // Helper para mostrar/ocultar y REMOVER si no tiene permiso
                    function syncUI(id, hasPerm, targetSectionId) {
                        const el = document.getElementById(id) || document.querySelector(`button[onclick*="nav('${targetSectionId}')"]`);
                        if (el) {
                            if (hasPerm) {
                                el.style.display = 'flex';
                            } else {
                                el.remove(); // 🔴 Regla: Si no tiene permiso, NO EXISTE en la UI
                                const section = document.getElementById(targetSectionId);
                                if (section && section.classList.contains('active')) {
                                    // Redirigir a un módulo seguro (Horarios es el más básico)
                                    global.nav('schedule');
                                }
                            }
                        }
                    }

                    syncUI(null, perms.upload, 'upload');
                    syncUI(null, perms.horarios, 'schedule');
                    syncUI(null, perms.obs, 'observations');
                    syncUI(null, perms.rpt, 'rpt-planilla');
                    syncUI(null, perms.docentes, 'docentes');
                    syncUI('nav-btn-usuarios', perms.usuarios, 'usuarios-module');

                    // Configuración (Dropdown)
                    const configBtn = document.querySelector('button[onclick="toggleConfigMenu()"]');
                    if (configBtn && !perms.config) configBtn.remove();
                    
                    // Botones de acción específicos
                    const uploaderBtn = document.getElementById('btn-upload-xml');
                    if (uploaderBtn && !perms.upload) uploaderBtn.remove();
                    
                    const exportBtn = document.getElementById('btn-export-rpt');
                    if (exportBtn && !global.hasPermission("exportar_rpt")) exportBtn.remove();
                }

                global.applyRBAC = applyRBAC;
            })(window);

            // ==========================================
            // MÓDULO 5: LOGIN UI (Encapsulado total)
            // ==========================================
            (function (global) {
                document.addEventListener('DOMContentLoaded', () => {
                    const form = document.getElementById('login-form');
                    if (!form) return;

                    form.addEventListener('submit', async (e) => {
                        e.preventDefault();
                        const payload = new URLSearchParams();
                        payload.append('username', document.getElementById('login-username').value.trim());
                        payload.append('password', document.getElementById('login-password').value);

                        const btn = document.getElementById('login-btn');
                        const err = document.getElementById('login-error');
                        err.classList.add('hidden');
                        btn.disabled = true;
                        btn.innerHTML = 'Validando <i class="fa-solid fa-spinner fa-spin"></i>';

                        try {
                            const res = await global.authFetch(window.CONFIG.BASE_URL + '/api/users/login', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                                body: payload
                            });

                            const data = await res.json();
                            if (!res.ok) throw new Error(data.detail || 'Fallo de autenticación.');

                            global.setToken(data.access_token);
                            await global.initApp();
                            global.nav('upload');

                        } catch (e) {
                            err.innerText = e.message;
                            err.classList.remove('hidden');
                        } finally {
                            btn.disabled = false;
                            btn.innerHTML = 'Ingresar <i class="fa-solid fa-arrow-right"></i>';
                        }
                    });
                });
            })(window);

            // ==========================================
            // MÓDULO 6: GESTIÓN DE SISTEMA (USERS)
            // ==========================================
            (function (global) {
                let globalRoles = [];
                let globalPermissions = [];
                let currentResetUserId = null;

                function toggleUsuariosTab(tab) {
                    document.querySelectorAll('.usr-tab-btn').forEach(b => b.classList.remove('border-indigo-600', 'text-indigo-600'));
                    document.getElementById(`usr-tab-btn-${tab}`).classList.add('border-indigo-600', 'text-indigo-600');
                    document.getElementById('usr-tab-list').classList.toggle('hidden', tab !== 'list');
                    document.getElementById('usr-tab-rbac').classList.toggle('hidden', tab !== 'rbac');
                    if (tab === 'rbac') loadRBACMatrix();
                }

                async function loadSysRoles() {
                    const res = await global.authFetch(`${window.CONFIG.BASE_URL}/api/roles`);
                    globalRoles = await res.json();
                }

                async function loadSysPermissions() {
                    const res = await global.authFetch(`${window.CONFIG.BASE_URL}/api/permissions`);
                    globalPermissions = await res.json();
                }

                async function loadUsuarios() {
                    const tbody = document.getElementById('usuarios-tbody');
                    if (!tbody) return;
                    tbody.innerHTML = '<tr><td colspan="5" class="px-5 py-8 text-center text-indigo-500"><i class="fa-solid fa-spinner fa-spin mr-2"></i>Cargando...</td></tr>';

                    await loadSysRoles();

                    try {
                        const res = await global.authFetch(`${window.CONFIG.BASE_URL}/api/users`);
                        const list = await res.json();
                        tbody.innerHTML = '';

                        list.forEach(u => {
                            const statusUI = u.is_active
                                ? `<span class="bg-emerald-100 text-emerald-700 text-[10px] px-2 py-1 rounded-full font-black">ACTIVO</span>`
                                : `<span class="bg-rose-100 text-rose-700 text-[10px] px-2 py-1 rounded-full font-black">BLOQUEADO</span>`;

                            const rolesUI = u.roles.map(r => `<span class="text-[10px] border border-slate-300 text-slate-600 bg-white px-2 py-0.5 rounded-lg font-bold">${r.name}</span>`).join(' ') || '<em class="text-xs text-slate-400">Sin roles</em>';

                            tbody.innerHTML += `
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-5 py-4">
                                        <p class="font-bold text-slate-800">${u.apellidos}, ${u.nombres}</p>
                                        <p class="text-xs text-slate-500">${u.area || '-'}</p>
                                    </td>
                                    <td class="px-5 py-4 font-medium text-slate-700">${u.username}</td>
                                    <td class="px-5 py-4 flex gap-1 flex-wrap">${rolesUI}</td>
                                    <td class="px-5 py-4">${statusUI}</td>
                                    <td class="px-5 py-4 text-right space-x-2">
                                        <button onclick='window.openResetPwdModal(${u.id}, "${u.username}")' class="text-rose-600 hover:bg-rose-50 border border-rose-100 font-bold px-3 py-1.5 rounded-lg text-[10px] uppercase tracking-tighter" title="Resetear Contraseña"><i class="fa-solid fa-key"></i></button>
                                        <button onclick='window.editUsuario(${JSON.stringify(u).replace(/'/g, "&#39;")})' class="bg-indigo-50 text-indigo-700 hover:bg-indigo-100 font-bold px-3 py-1.5 rounded-lg text-xs"><i class="fa-solid fa-pen"></i> Editar</button>
                                        ${u.is_active ? `<button onclick="window.deleteUsuario(${u.id})" class="bg-rose-50 text-rose-700 hover:bg-rose-100 font-bold px-3 py-1.5 rounded-lg text-xs"><i class="fa-solid fa-ban"></i></button>` : ''}
                                    </td>
                                </tr>
                            `;
                        });
                    } catch (e) {
                        tbody.innerHTML = `<tr><td colspan="5" class="px-5 py-8 text-center text-rose-500 font-bold">Error: ${e.message}</td></tr>`;
                    }
                }

                // --- RBAC Matrix Logic ---
                async function loadRBACMatrix() {
                    const thead = document.getElementById('rbac-thead');
                    const tbody = document.getElementById('rbac-tbody');
                    thead.innerHTML = '<tr><th class="px-6 py-4">Cargando...</th></tr>';
                    tbody.innerHTML = '';

                    try {
                        await Promise.all([loadSysRoles(), loadSysPermissions()]);

                        // Header (Roles)
                        let header = `<tr><th class="px-6 py-4 text-xs font-black text-slate-500 uppercase tracking-widest bg-slate-50 sticky left-0 z-10 w-64">Permisos / Funcionalidad</th>`;
                        globalRoles.forEach(r => {
                            header += `<th class="px-4 py-4 text-center text-[10px] font-black text-slate-600 uppercase tracking-tighter w-32 border-l border-slate-200">${r.name}</th>`;
                        });
                        header += `</tr>`;
                        thead.innerHTML = header;

                        // Body (Permissions)
                        globalPermissions.forEach(p => {
                            let row = `<tr class="hover:bg-slate-50">
                                <td class="px-6 py-4 bg-white sticky left-0 z-10 border-r border-slate-100 shadow-[2px_0_5px_rgba(0,0,0,0.02)]">
                                    <p class="font-bold text-slate-800 text-sm">${p.description || p.name}</p>
                                    <p class="text-[10px] text-slate-400 font-mono">${p.name}</p>
                                </td>`;
                            
                            globalRoles.forEach(r => {
                                const hasPerm = r.permissions.some(rp => rp.id === p.id);
                                row += `<td class="px-4 py-4 text-center border-l border-slate-100">
                                    <input type="checkbox" class="rbac-check w-5 h-5 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" 
                                           data-role-id="${r.id}" data-perm-id="${p.id}" ${hasPerm ? 'checked' : ''}>
                                </td>`;
                            });
                            row += `</tr>`;
                            tbody.insertAdjacentHTML('beforeend', row);
                        });
                    } catch (e) { console.error(e); }
                }

                async function saveRolePermissions() {
                    const btn = document.getElementById('btn-save-rbac');
                    const orig = btn.innerHTML;
                    btn.disabled = true; btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Guardando...';

                    try {
                        const checks = document.querySelectorAll('.rbac-check');
                        const matrix = {};
                        checks.forEach(c => {
                            const rid = c.dataset.roleId;
                            const pid = parseInt(c.dataset.permId);
                            if (!matrix[rid]) matrix[rid] = [];
                            if (c.checked) matrix[rid].push(pid);
                        });

                        const promises = Object.entries(matrix).map(([rid, pids]) => 
                            global.authFetch(`${window.CONFIG.BASE_URL}/api/roles/${rid}/permissions`, {
                                method: 'POST', headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ permission_ids: pids })
                            })
                        );

                        await Promise.all(promises);
                        alert('✅ Matriz de permisos actualizada correctamente.');
                    } catch (e) {
                         alert('❌ Error al guardar permisos: ' + e.message);
                    } finally {
                        btn.disabled = false; btn.innerHTML = orig;
                    }
                }

                // --- Password Reset ---
                function openResetPwdModal(id, username) {
                    currentResetUserId = id;
                    document.getElementById('reset-pwd-user').textContent = username;
                    document.getElementById('new-pwd-input').value = '';
                    document.getElementById('reset-pwd-modal').classList.remove('hidden');
                }
                function closeResetPwdModal() { document.getElementById('reset-pwd-modal').classList.add('hidden'); }

                async function confirmResetPassword() {
                    const pwd = document.getElementById('new-pwd-input').value.trim();
                    if (pwd.length < 6) { alert('Mínimo 6 caracteres.'); return; }
                    
                    const btn = document.getElementById('btn-confirm-reset-pwd');
                    const orig = btn.innerHTML;
                    btn.disabled = true; btn.innerHTML = 'Procesando...';

                    try {
                        const res = await global.authFetch(`${window.CONFIG.BASE_URL}/api/users/${currentResetUserId}/password`, {
                            method: 'PUT', headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ new_password: pwd })
                        });
                        if (res.ok) {
                            alert('✅ Contraseña actualizada.');
                            closeResetPwdModal();
                        } else {
                            const err = await res.json();
                            alert('Error: ' + (err.detail || 'Fallo inesperado'));
                        }
                    } catch (e) { alert(e.message); } finally { btn.disabled = false; btn.innerHTML = orig; }
                }

                function buildRolesCheckboxes(activeIds = []) {
                    const wrapper = document.getElementById('usr-roles-container');
                    if (!wrapper) return;
                    wrapper.innerHTML = '';
                    globalRoles.forEach(r => {
                        const checked = activeIds.includes(r.id) ? 'checked' : '';
                        wrapper.innerHTML += `
                            <label class="flex items-center gap-2 cursor-pointer bg-slate-50 p-2 rounded border border-slate-200 hover:bg-white transition-all">
                                <input type="checkbox" name="rol_assign" value="${r.id}" ${checked} class="rounded border-slate-300 text-indigo-600">
                                <span class="text-[10px] font-black text-slate-700 uppercase tracking-widest">${r.name}</span>
                            </label>
                        `;
                    });
                }

                function openUsuarioModal() {
                    document.getElementById('usuario-form').reset();
                    document.getElementById('usr-id').value = '';
                    document.getElementById('usuario-modal-title').innerText = 'Nuevo Usuario';
                    document.getElementById('usr-password').required = true;
                    document.getElementById('usr-pwd-container').style.display = 'block';

                    buildRolesCheckboxes();
                    document.getElementById('usuario-modal').classList.remove('hidden');
                }

                function editUsuario(u) {
                    document.getElementById('usuario-form').reset();
                    document.getElementById('usr-id').value = u.id;
                    document.getElementById('usr-nombres').value = u.nombres;
                    document.getElementById('usr-apellidos').value = u.apellidos;
                    document.getElementById('usr-email').value = u.username;
                    document.getElementById('usr-area').value = u.area || '';

                    document.getElementById('usuario-modal-title').innerText = 'Modificar Acceso';
                    document.getElementById('usr-password').required = false;
                    document.getElementById('usr-pwd-container').style.display = 'none';

                    buildRolesCheckboxes(u.roles.map(r => r.id));
                    document.getElementById('usuario-modal').classList.remove('hidden');
                }

                function closeUsuarioModal() { document.getElementById('usuario-modal').classList.add('hidden'); }

                document.addEventListener('DOMContentLoaded', () => {
                    document.getElementById('usuario-form')?.addEventListener('submit', async (e) => {
                        e.preventDefault();
                        const btn = document.getElementById('usr-save-btn');
                        const orig = btn.innerHTML;
                        btn.disabled = true; btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';

                        const id = document.getElementById('usr-id').value;
                        const payload = {
                            username: document.getElementById('usr-email').value,
                            nombres: document.getElementById('usr-nombres').value,
                            apellidos: document.getElementById('usr-apellidos').value,
                            area: document.getElementById('usr-area').value
                        };
                        if (!id) payload.password = document.getElementById('usr-password').value;

                        try {
                            let targetId = id;
                            if (id) {
                                await global.authFetch(`${window.CONFIG.BASE_URL}/api/users/${id}`, {
                                    method: 'PUT', headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify(payload)
                                });
                            } else {
                                const res = await global.authFetch(`${window.CONFIG.BASE_URL}/api/users`, {
                                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify(payload)
                                });
                                const created = await res.json();
                                targetId = created.id;
                            }

                            const roleIds = Array.from(document.querySelectorAll('input[name="rol_assign"]:checked')).map(cb => parseInt(cb.value));
                            await global.authFetch(`${window.CONFIG.BASE_URL}/api/users/${targetId}/roles`, {
                                method: 'POST', headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ role_ids: roleIds })
                            });

                            closeUsuarioModal();
                            loadUsuarios();
                        } catch (e) {
                            alert("Error guardando usuario: " + e.message);
                        } finally {
                            btn.disabled = false; btn.innerHTML = orig;
                        }
                    });
                });

                async function deleteUsuario(id) {
                    if (!confirm('¿Desactivar y bloquear el acceso de este usuario?')) return;
                    try {
                        await global.authFetch(`${window.CONFIG.BASE_URL}/api/users/${id}`, { method: 'DELETE' });
                        loadUsuarios();
                    } catch (e) { alert('Error: ' + e.message); }
                }

                // Expose Functions
                global.toggleUsuariosTab = toggleUsuariosTab;
                global.loadUsuarios = loadUsuarios;
                global.openUsuarioModal = openUsuarioModal;
                global.editUsuario = editUsuario;
                global.closeUsuarioModal = closeUsuarioModal;
                global.deleteUsuario = deleteUsuario;
                global.saveRolePermissions = saveRolePermissions;
                global.openResetPwdModal = openResetPwdModal;
                global.closeResetPwdModal = closeResetPwdModal;
                global.confirmResetPassword = confirmResetPassword;

            })(window);


            // ==========================================
            // MÓDULO 7: LEGACY BUSINESS LOGIC
            // ==========================================
(function (global) {

                // --- Constants & Global State ---
                let currentConfigs = { recess: [], lunch: [] };
                let teachersData = [];

                async function loadRptPlanilla() {
                    const tbody = document.getElementById("rpt-tbody");
                    if (!tbody) return;

                    try {
                        console.log("🚀 Entrando a RPT");
                        tbody.innerHTML = '<tr><td colspan="10" class="text-center py-10"><i class="fa-solid fa-circle-notch fa-spin text-indigo-500 mr-2"></i>Cargando datos...</td></tr>';

                        const start = document.getElementById('rpt-start-date').value;
                        const end = document.getElementById('rpt-end-date').value;
                        const docente = document.getElementById('rpt-filter-docente').value;
                        const sede = document.getElementById('rpt-filter-sede').value;
                        const aula = document.getElementById('rpt-filter-aula').value;

                        if (!start || !end) {
                            tbody.innerHTML = '<tr><td colspan="10" class="text-center py-10 text-slate-400">Selecciona un rango de fechas</td></tr>';
                            return;
                        }

                        let url = `${window.CONFIG.BASE_URL}/api/rpt-planilla/?fecha_inicio=${start}&fecha_fin=${end}&page=${rptCurrentPage}&limit=50`;
                        if (docente) url += `&docente=${encodeURIComponent(docente)}`;
                        if (sede) url += `&sede=${encodeURIComponent(sede)}`;
                        if (aula) url += `&aula=${encodeURIComponent(aula)}`;

                        const res = await authFetch(url);
                        const json = await res.json();
                        
                        console.log("📦 DATA RPT:", json);

                        const rows = json.data || (Array.isArray(json) ? json : []);

                        if (rows.length === 0) {
                            tbody.innerHTML = '<tr><td colspan="10" class="text-center py-10 text-slate-400">No se encontraron registros para los filtros aplicados</td></tr>';
                            updateRptPagination(1, 1);
                            return;
                        }

                        renderRpt(rows);
                        updateRptPagination(json.current_page || 1, json.total_pages || 1);

                    } catch (e) {
                        console.error("❌ Error RPT:", e);
                        tbody.innerHTML = `<tr><td colspan="10" class="text-center py-10 text-rose-500 font-bold"><i class="fa-solid fa-triangle-exclamation mr-2"></i>Error: ${e.message}</td></tr>`;
                    } finally {
                        console.log("✅ RPT finalizado");
                    }
                }

                async function loadConfig(type) {
                    const endpoint = type === 'recess' ? 'recesos' : 'almuerzos';
                    try {
                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/config/${endpoint}`);
                        if (!res.ok) throw new Error(`HTTP ${res.status}`);
                        const data = await res.json();
                        if (data.success) {
                            currentConfigs[type] = data.data;
                            renderConfigTable(type);
                        }
                    } catch (e) {
                        console.error(`Error loading ${type}:`, e);
                    }
                }

                // Navigation Logic

                function nav(sectionId) {
                    // Eliminar active de todos los nav-btn salvo config
                    document.querySelectorAll('.nav-btn').forEach(btn => {
                        btn.classList.remove('bg-indigo-600', 'text-white', 'shadow-md', 'shadow-indigo-900/50');
                        if (!btn.classList.contains('text-slate-300')) {
                            btn.classList.add('text-slate-300', 'hover:bg-slate-800');
                        }
                    });

                    // Resaltar el seleccionado
                    const activeBtn = Array.from(document.querySelectorAll('.nav-btn')).find(b => b.getAttribute('onclick') === "nav('" + sectionId + "')");
                    if (activeBtn) {
                        activeBtn.classList.add('bg-indigo-600', 'text-white', 'shadow-md', 'shadow-indigo-900/50');
                        activeBtn.classList.remove('text-slate-300', 'hover:bg-slate-800');
                    }

                    document.querySelectorAll('.section').forEach(el => el.classList.remove('active'));
                    const targetSection = document.getElementById(sectionId);
                    if (targetSection) {
                        targetSection.classList.add('active');
                        if (sectionId === 'usuarios-module') loadUsuarios();
                    }
                }


                function renderConfigTable(type) {
                    const tbody = document.getElementById(`${type}-config-body`);
                    tbody.innerHTML = '';
                    const configs = currentConfigs[type];

                    if (configs.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="5" class="py-12 text-center text-slate-400 italic">No hay registros configurados</td></tr>';
                        return;
                    }

                    configs.forEach(c => {
                        const tr = document.createElement('tr');
                        tr.className = "hover:bg-slate-50 transition-colors border-b border-slate-50 text-slate-700 not-italic";

                        // Calculate duration for display
                        const dur = calculateDurationMinutes(c.start_time, c.end_time);

                        tr.innerHTML = `
                    <td class="px-6 py-4 font-bold text-slate-800">${c.description}</td>
                    <td class="px-6 py-4 font-mono text-sm">${c.start_time.substring(0, 5)}</td>
                    <td class="px-6 py-4 font-mono text-sm">${c.end_time.substring(0, 5)}</td>
                    <td class="px-6 py-4 text-center">
                        <span class="bg-indigo-50 text-indigo-700 px-3 py-1 rounded-full text-xs font-black">${dur} min</span>
                    </td>
                    <td class="px-6 py-4 text-right space-x-2">
                        <button onclick="editConfig('${type}', ${c.id})" class="text-indigo-600 hover:text-indigo-800 p-2"><i class="fa-solid fa-pen-to-square"></i></button>
                        <button onclick="deleteConfig('${type}', ${c.id})" class="text-rose-600 hover:text-rose-800 p-2"><i class="fa-solid fa-trash"></i></button>
                    </td>
                `;
                        tbody.appendChild(tr);
                    });
                }

                function calculateDurationMinutes(start, end) {
                    if (!start || !end) return 0;
                    const [h1, m1] = start.split(':').map(Number);
                    const [h2, m2] = end.split(':').map(Number);
                    return (h2 * 60 + m2) - (h1 * 60 + m1);
                }

                function calculateDuration() {
                    const start = document.getElementById('config-start').value;
                    const end = document.getElementById('config-end').value;
                    if (start && end) {
                        const diff = calculateDurationMinutes(start, end);
                        document.getElementById('config-duration').innerText = `${diff} min`;
                        if (diff <= 0) document.getElementById('config-duration').classList.add('text-rose-600');
                        else document.getElementById('config-duration').classList.remove('text-rose-600');
                    }
                }

                function openConfigModal(type, id = null) {
                    const isEdit = id !== null;
                    document.getElementById('config-type').value = type;
                    document.getElementById('config-id').value = id || '';
                    document.getElementById('config-modal-title').innerText = `${isEdit ? 'Editar' : 'Agregar'} ${type === 'recess' ? 'Receso' : 'Almuerzo'}`;

                    if (isEdit) {
                        const config = currentConfigs[type].find(c => c.id === id);
                        document.getElementById('config-name').value = config.description;
                        document.getElementById('config-start').value = config.start_time.substring(0, 5);
                        document.getElementById('config-end').value = config.end_time.substring(0, 5);
                    } else {
                        document.getElementById('config-name').value = '';
                        document.getElementById('config-start').value = '';
                        document.getElementById('config-end').value = '';
                    }

                    calculateDuration();
                    document.getElementById('config-modal').classList.remove('hidden');
                }

                function closeConfigModal() {
                    document.getElementById('config-modal').classList.add('hidden');
                }

                async function saveConfig() {
                    if (!global.hasPermission('gestionar_configuracion')) {
                        alert("No tienes permiso 'gestionar_configuracion'");
                        return;
                    }
                    const type = document.getElementById('config-type').value;
                    const id = document.getElementById('config-id').value;
                    const payload = {
                        description: document.getElementById('config-name').value,
                        start_time: document.getElementById('config-start').value,
                        end_time: document.getElementById('config-end').value
                    };

                    if (!payload.description || !payload.start_time || !payload.end_time) {
                        alert("Complete todos los campos.");
                        return;
                    }

                    if (calculateDurationMinutes(payload.start_time, payload.end_time) <= 0) {
                        alert("La hora de fin debe ser posterior a la de inicio.");
                        return;
                    }

                    const endpoint = type === 'recess' ? 'recesos' : 'almuerzos';
                    const method = id ? 'PUT' : 'POST';
                    const url = id ? `${window.CONFIG.BASE_URL}/api/config/${endpoint}/${id}` : `${window.CONFIG.BASE_URL}/api/config/${endpoint}`;

                    try {
                        const res = await authFetch(url, {
                            method: method,
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });

                        if (!res.ok) {
                            const err = await res.json();
                            console.error("Error saving:", err);
                            alert("Error al guardar: " + (typeof err.detail === 'string' ? err.detail : JSON.stringify(err.detail)));
                            return;
                        }

                        const data = await res.json();
                        if (data.success) {
                            closeConfigModal();
                            loadConfig(type);
                            alert("Configuración guardada con éxito");
                        }
                    } catch (e) {
                        console.error("Error saving config:", e);
                        alert("Error de conexión: " + e.message);
                    }
                }

                async function deleteConfig(type, id) {
                    if (!confirm("¿Está seguro de eliminar este registro?")) return;
                    const endpoint = type === 'recess' ? 'recesos' : 'almuerzos';
                    try {
                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/config/${endpoint}/${id}`, { method: 'DELETE' });
                        const data = await res.json();
                        if (data.success) loadConfig(type);
                    } catch (e) {
                        console.error("Error deleting config:", e);
                    }
                }

                function editConfig(type, id) {
                    openConfigModal(type, id);
                }

                // Upload Logic
                let currentHistoryPage = 1;

                async function loadUploadHistory(page = 1) {
                    currentHistoryPage = page;
                    const tbody = document.getElementById('upload-history-body');
                    const prevBtn = document.getElementById('prev-page-btn');
                    const nextBtn = document.getElementById('next-page-btn');
                    const pageIndicator = document.getElementById('page-indicator');
                    const totalCount = document.getElementById('history-total');

                    try {
                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/schedule/xml-uploads?page=${page}&limit=5`);
                        const data = await res.json();
                        if (data.success) {
                            tbody.innerHTML = '';
                            if (data.data.length === 0) {
                                tbody.innerHTML = '<tr><td colspan="4" class="px-4 py-8 text-center text-slate-400">No hay registros de subida aún.</td></tr>';
                                pageIndicator.innerText = `Página 1 de 1`;
                                totalCount.innerText = "0";
                                return;
                            }

                            // Update metadata
                            totalCount.innerText = data.total_records;
                            pageIndicator.innerText = `Página ${data.current_page} de ${data.total_pages}`;
                            prevBtn.disabled = data.current_page <= 1;
                            nextBtn.disabled = data.current_page >= data.total_pages;

                            data.data.forEach(u => {
                                const tr = document.createElement('tr');
                                tr.className = "hover:bg-slate-50 transition-colors";
                                tr.innerHTML = `
                            <td class="px-4 py-3 font-medium text-slate-700">${u.created_at}</td>
                            <td class="px-4 py-3 text-slate-600">${u.filename}</td>
                            <td class="px-4 py-3 text-slate-600">${u.start_date} a ${u.end_date}</td>
                            <td class="px-4 py-3 text-center">
                                ${u.is_force_overwrite
                                        ? '<span class="bg-amber-100 text-amber-700 text-[10px] font-black px-2 py-0.5 rounded-full uppercase tracking-tighter">SÍ</span>'
                                        : '<span class="bg-slate-100 text-slate-500 text-[10px] font-black px-2 py-0.5 rounded-full uppercase tracking-tighter">NO</span>'}
                            </td>
                        `;
                                tbody.appendChild(tr);
                            });
                        }
                    } catch (e) {
                        console.error("Error loading history:", e);
                        tbody.innerHTML = '<tr><td colspan="4" class="px-4 py-8 text-center text-rose-500 font-bold">Error cargando historial</td></tr>';
                    }
                }

                function changeHistoryPage(delta) {
                    loadUploadHistory(currentHistoryPage + delta);
                }

                // RPT Planilla Logic
                let rptCurrentPage = 1;

                function setInitialDates() {
                    const now = new Date();
                    const firstDay = new Date(now.getFullYear(), now.getMonth(), 1);

                    document.getElementById('rpt-fecha-inicio').value = firstDay.toISOString().split('T')[0];
                    document.getElementById('rpt-fecha-fin').value = now.toISOString().split('T')[0];
                }

                async function loadRptCatalogs() {
                    try {
                        const [resDoc, resSede] = await Promise.all([
                            authFetch(`${window.CONFIG.BASE_URL}/api/rpt-planilla/docentes`),
                            authFetch(`${window.CONFIG.BASE_URL}/api/rpt-planilla/sedes`)
                        ]);

                        const dataDoc = await resDoc.json();
                        const dataSede = await resSede.json();

                        if (dataDoc.success) {
                            const sel = document.getElementById('rpt-filter-docente');
                            sel.innerHTML = '<option value="Todos">Todos</option>';
                            dataDoc.data.forEach(d => {
                                const opt = document.createElement('option');
                                opt.value = d;
                                opt.textContent = d;
                                sel.appendChild(opt);
                            });
                        }

                        if (dataSede.success) {
                            const sel = document.getElementById('rpt-filter-sede');
                            sel.innerHTML = '<option value="Todas">Todas</option>';
                            dataSede.data.forEach(s => {
                                const opt = document.createElement('option');
                                opt.value = s;
                                opt.textContent = s;
                                sel.appendChild(opt);
                            });
                        }
                    } catch (e) {
                        console.error("Error loading RPT catalogs:", e);
                    }
                }

                async function handleSedeChange() {
                    const sede = document.getElementById('rpt-filter-sede').value;
                    const selAula = document.getElementById('rpt-filter-aula');

                    if (sede === "Todas") {
                        selAula.disabled = true;
                        selAula.innerHTML = '<option value="Todos">Todos</option>';
                        return;
                    }

                    selAula.disabled = false;
                    selAula.innerHTML = '<option value="Todos">Cargando...</option>';

                    try {
                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/rpt-planilla/aulas?sede=${encodeURIComponent(sede)}`);
                        const data = await res.json();

                        if (data.success) {
                            selAula.innerHTML = '<option value="Todos">Todos</option>';
                            data.data.forEach(a => {
                                const opt = document.createElement('option');
                                opt.value = a;
                                opt.textContent = a;
                                selAula.appendChild(opt);
                            });
                        }
                    } catch (e) {
                        console.error("Error loading aulas:", e);
                    }
                }

                async function loadRptPlanilla(page = 1) {
                    rptCurrentPage = page;
                    const tbody = document.getElementById('rpt-planilla-body');
                    if (!tbody) {
                        console.error("❌ ERROR: No se encontró el contenedor 'rpt-planilla-body'.");
                        return;
                    }

                    try {
                        // 1. Lectura segura de filtros (Previene crasheo síncrono inicial)
                        const inicioEl = document.getElementById('rpt-fecha-inicio');
                        const finEl = document.getElementById('rpt-fecha-fin');

                        if (!inicioEl?.value || !finEl?.value) {
                            alert("Por favor, seleccione un rango de fechas válido.");
                            return;
                        }

                        const inicio = inicioEl.value;
                        const fin = finEl.value;
                        const docente = document.getElementById('rpt-filter-docente')?.value || "Todos";
                        const sede = document.getElementById('rpt-filter-sede')?.value || "Todas";
                        const aula = document.getElementById('rpt-filter-aula')?.value || "Todos";

                        // 2. Estado de Carga (Spinner)
                        tbody.innerHTML = `
                            <tr>
                                <td colspan="10" class="px-4 py-12 text-center text-slate-400">
                                    <i class="fa-solid fa-spinner fa-spin text-2xl mb-3 block"></i>
                                    Filtrando resultados...
                                </td>
                            </tr>`;

                        console.log("🚀 Solicitando reporte de RPT...");

                        let url = `${window.CONFIG.BASE_URL}/api/rpt-planilla/?fecha_inicio=${inicio}&fecha_fin=${fin}&page=${page}&limit=50`;
                        if (docente !== "Todos") url += `&docente=${encodeURIComponent(docente)}`;
                        if (sede !== "Todas") url += `&sede=${encodeURIComponent(sede)}`;
                        if (aula !== "Todos") url += `&aula=${encodeURIComponent(aula)}`;

                        const res = await authFetch(url);
                        console.log("📡 STATUS RPT:", res.status);

                        if (!res.ok) {
                            tbody.innerHTML = `
                                <tr>
                                    <td colspan="10" class="px-4 py-12 text-center text-rose-500 font-bold">
                                        <i class="fa-solid fa-circle-exclamation text-2xl mb-2 block"></i><br>
                                        Error al cargar (HTTP ${res.status}).
                                        ${res.status === 403 ? "Sin permisos suficientes." : "Revisa el servidor."}
                                    </td>
                                </tr>`;
                            return;
                        }

                        const data = await res.json();
                        const dataset = data.data || (Array.isArray(data) ? data : []);

                        if (!Array.isArray(dataset) || dataset.length === 0) {
                            tbody.innerHTML = '<tr><td colspan="10" class="px-4 py-16 text-center text-slate-400 font-medium italic">" Todavía no se cargan estos datos a la bd "</td></tr>';
                            if (document.getElementById('rpt-total-records')) document.getElementById('rpt-total-records').innerText = "0";
                            return;
                        }

                        // 3. Renderizado y Metadata
                        tbody.innerHTML = '';
                        if (document.getElementById('rpt-summary-panel')) document.getElementById('rpt-summary-panel').classList.remove('hidden');
                        if (document.getElementById('rpt-sum-hours')) document.getElementById('rpt-sum-hours').innerText = (data.total_hours_sum || 0).toFixed(2);
                        if (document.getElementById('rpt-count-recesos')) document.getElementById('rpt-count-recesos').innerText = data.total_receso_count || 0;

                        if (document.getElementById('rpt-total-records')) document.getElementById('rpt-total-records').innerText = data.total_records || dataset.length;
                        if (document.getElementById('rpt-page-indicator')) document.getElementById('rpt-page-indicator').innerText = `Página ${data.current_page || 1} de ${data.total_pages || 1}`;
                        if (document.getElementById('rpt-prev-btn')) document.getElementById('rpt-prev-btn').disabled = (data.current_page || 1) <= 1;
                        if (document.getElementById('rpt-next-btn')) document.getElementById('rpt-next-btn').disabled = (data.current_page || 1) >= (data.total_pages || 1);

                        dataset.forEach(r => {
                            const tr = document.createElement('tr');
                            const obs = r.observation;
                            const isRepl = r.is_replacement;

                            let rowClass = "hover:bg-slate-50 transition-colors border-b border-slate-50";
                            let extraInfo = "";
                            let hoursDisplay = (r.horas_dictadas || 0).toFixed(2);
                            let recesoDisplay = (r.receso || 0).toFixed(2);

                            if (obs && !isRepl) {
                                const types = obs.type.split(', ');
                                const obsIds = obs.ids || [];
                                let labelsHtml = '';

                                types.forEach((t, idx) => {
                                    const currentObsId = obsIds[idx];
                                    const deleteBtn = currentObsId ? `<button onclick="deleteObservation(${currentObsId})" class="ml-1 opacity-0 group-hover:opacity-100 hover:text-white transition-all" title="Eliminar ${t}"><i class="fa-solid fa-xmark"></i></button>` : '';

                                    if (['FALTA', 'VACACIONES', 'DESCANSO_MEDICO'].includes(t)) {
                                        labelsHtml += `<span class="bg-rose-100 text-rose-700 px-1.5 py-0.5 rounded-md text-[9px] font-black uppercase inline-flex items-center gap-1 my-0.5 mr-1 group/tag"><i class="fa-solid fa-circle-exclamation"></i> ${t}${deleteBtn}</span>`;
                                    } else if (t === 'REEMPLAZO') {
                                        labelsHtml += `<span class="bg-amber-100 text-amber-700 px-1.5 py-0.5 rounded-md text-[9px] font-black uppercase inline-flex items-center gap-1 my-0.5 mr-1 group/tag" title="Reemplazado por: ${obs.replacement_teacher_name || '---'}"><i class="fa-solid fa-user-group"></i> REEMPLAZO${deleteBtn}</span>`;
                                    }
                                });

                                if (obs.has_discount_impact) {
                                    rowClass = "bg-rose-50/50 text-rose-900 border-b border-rose-100";
                                }
                                extraInfo = `<div class="flex flex-wrap mt-1">${labelsHtml}</div>`;
                            }

                            if (isRepl) {
                                rowClass = "bg-amber-50 text-amber-900 border-b border-amber-100 font-medium";
                                extraInfo = `<div class="mt-1"><span class="bg-amber-600 text-white px-1.5 py-0.5 rounded-md text-[9px] font-black uppercase inline-flex items-center gap-1"><i class="fa-solid fa-award"></i> REEMPLAZO</span> <span class="text-[10px] opacity-70 italic ml-1">(Titular: ${r.titular_original})</span></div>`;
                            }

                            tr.className = rowClass;
                            tr.innerHTML = `
                        <td class="px-4 py-3 font-medium">${r.fecha_clase}</td>
                        <td class="px-4 py-3">${r.sede}</td>
                        <td class="px-4 py-3 font-bold">${r.ciclo}</td>
                        <td class="px-4 py-3 font-medium">
                            ${r.docente}
                            ${extraInfo}
                        </td>
                        <td class="px-4 py-3 text-xs">${r.curso}</td>
                        <td class="px-4 py-3 font-mono text-xs">${r.hora_inicio.substring(0, 5)}</td>
                        <td class="px-4 py-3 font-mono text-xs">${r.hora_fin.substring(0, 5)}</td>
                        <td class="px-4 py-3 text-center font-black">${hoursDisplay}</td>
                        <td class="px-4 py-3 text-center font-bold">${recesoDisplay}</td>
                    `;
                            tbody.appendChild(tr);
                        });

                    } catch (e) {
                        console.error("❌ ERROR RPT:", e);
                        tbody.innerHTML = '<tr><td colspan="10" class="px-4 py-12 text-center text-rose-500 font-bold">Error conectando con el servidor</td></tr>';
                    } finally {
                        console.log("🧹 Limpieza de loading RPT");
                    }
                }

                function changeRptPage(delta) {
                    loadRptPlanilla(rptCurrentPage + delta);
                }

                async function exportToExcel() {
                    const inicio = document.getElementById('rpt-fecha-inicio').value;
                    const fin = document.getElementById('rpt-fecha-fin').value;
                    const docente = document.getElementById('rpt-filter-docente').value;
                    const sede = document.getElementById('rpt-filter-sede').value;
                    const aula = document.getElementById('rpt-filter-aula').value;

                    if (!inicio || !fin) {
                        alert("Seleccione rango de fechas para exportar.");
                        return;
                    }

                    let url = `${window.CONFIG.BASE_URL}/api/rpt-planilla/export?fecha_inicio=${inicio}&fecha_fin=${fin}`;
                    if (docente !== "Todos") url += `&docente=${encodeURIComponent(docente)}`;
                    if (sede !== "Todas") url += `&sede=${encodeURIComponent(sede)}`;
                    if (aula !== "Todos") url += `&aula=${encodeURIComponent(aula)}`;

                    window.open(url, '_blank');
                }

                async function simulateUpload(overwrite = false) {
                    const btn = document.getElementById('upload-btn');
                    const fileInput = document.getElementById('file-upload');
                    const startDate = document.getElementById('start-date').value;
                    const endDate = document.getElementById('end-date').value;
                    const progressFill = document.getElementById('progress-bar-fill');
                    const statusLabel = document.getElementById('progress-status');

                    if (!fileInput.files.length || !startDate || !endDate) {
                        alert("Por favor selecciona un archivo XML, fecha inicio y fecha fin.");
                        return;
                    }

                    btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Procesando y Parseando...';
                    btn.disabled = true;
                    btn.classList.add('opacity-75');

                    document.getElementById('upload-progress').classList.remove('hidden');
                    document.getElementById('conflict-alert').classList.add('hidden');
                    closeOverwriteModal();

                    // Initial Animation
                    progressFill.style.width = "20%";

                    const formData = new FormData();
                    formData.append("file", fileInput.files[0]);
                    formData.append("start_date", startDate);
                    formData.append("end_date", endDate);
                    formData.append("force_overwrite", overwrite);

                    // Simulate steps for UI feel
                    setTimeout(() => {
                        progressFill.style.width = "45%";
                        document.getElementById('task-subjects').innerHTML = '<i class="fa-solid fa-check text-green-500 mr-2"></i> Extracción de Subjects';
                    }, 800);

                    setTimeout(() => {
                        progressFill.style.width = "70%";
                        document.getElementById('task-teachers').innerHTML = '<i class="fa-solid fa-check text-green-500 mr-2"></i> Extracción de Docentes';
                    }, 1800);

                    try {
                        const response = await authFetch(`${window.CONFIG.BASE_URL}/api/schedule/upload`, {
                            method: "POST",
                            body: formData
                        });

                        const data = await response.json();

                        if (!response.ok) {
                            document.getElementById('upload-progress').classList.add('hidden');

                            if (response.status === 400 && data.detail && data.detail.includes("force_overwrite=true")) {
                                // Caso específico de duplicados en rango
                                document.getElementById('overwrite-modal-msg').innerText = data.detail;
                                document.getElementById('overwrite-modal').classList.remove('hidden');
                                btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles"></i> Vincular y Procesar';
                                btn.disabled = false;
                                btn.classList.remove('opacity-75');
                            } else {
                                console.error("Error 400/500 Detail:", data);
                                const detail = typeof data.detail === 'string' ? data.detail : JSON.stringify(data.detail);
                                alert("Error del Servidor: " + (detail || "Error desconocido. Revisa la consola y la terminal."));
                                resetUpload();
                            }
                        } else {
                            progressFill.style.width = "100%";
                            statusLabel.innerText = "Finalizado";
                            document.getElementById('task-lessons').innerHTML = '<i class="fa-solid fa-check text-green-500 mr-2"></i> Generando Lesson Cards...';

                            setTimeout(() => {
                                alert(`¡Éxito! Horario procesado con ${data.records} sesiones.`);
                                resetUpload();
                                loadUploadHistory(); // Refrescar historial
                            }, 500);
                        }
                    } catch (error) {
                        document.getElementById('upload-progress').classList.add('hidden');
                        console.error("Upload error:", error);
                        alert("Error de red conectando con el backend FastAPI. \nMensaje: " + error.message);
                        resetUpload();
                    }
                }

                function closeOverwriteModal() {
                    document.getElementById('overwrite-modal').classList.add('hidden');
                }

                function confirmOverwrite() {
                    simulateUpload(true);
                }

                function resetUpload() {
                    const btn = document.getElementById('upload-btn');
                    document.getElementById('conflict-alert').classList.add('hidden');
                    document.getElementById('upload-progress').classList.add('hidden');
                    btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles"></i> Vincular y Procesar';
                    btn.disabled = false;
                    btn.classList.remove('opacity-75');
                    document.getElementById('file-upload').value = null;
                }
                // Drag and drop logic and File Input change

                // --- UNWRAPPED SCOPE ---

                // Cargar historial al inicio

                const dropZone = document.getElementById('drop-zone');
                const fileInput = document.getElementById('file-upload');
                const fileNameDisplay = document.getElementById('file-name-display');

                if (dropZone) {
                    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                        dropZone.addEventListener(eventName, e => {
                            e.preventDefault();
                            e.stopPropagation();
                        }, false);
                    });

                    ['dragenter', 'dragover'].forEach(eventName => {
                        dropZone.addEventListener(eventName, () => dropZone.classList.add('bg-indigo-50', 'border-indigo-400'), false);
                    });

                    ['dragleave', 'drop'].forEach(eventName => {
                        dropZone.addEventListener(eventName, () => dropZone.classList.remove('bg-indigo-50', 'border-indigo-400'), false);
                    });

                    dropZone.addEventListener('drop', (e) => {
                        const dt = e.dataTransfer;
                        fileInput.files = dt.files;
                        updateFileName();
                    }, false);
                }

                if (fileInput) {
                    fileInput.addEventListener('change', updateFileName);
                }

                function updateFileName() {
                    if (fileInput && fileInput.files.length > 0) {
                        fileNameDisplay.textContent = fileInput.files[0].name;
                        fileNameDisplay.classList.add('text-indigo-600');
                    } else if (fileNameDisplay) {
                        fileNameDisplay.textContent = "Arrastra tu XML aquí";
                        fileNameDisplay.classList.remove('text-indigo-600');
                    }
                }

                window.resetUpload = function () {
                    const btn = document.getElementById('upload-btn');
                    if (document.getElementById('conflict-alert')) document.getElementById('conflict-alert').classList.add('hidden');
                    if (document.getElementById('upload-progress')) document.getElementById('upload-progress').classList.add('hidden');
                    if (btn) {
                        btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles"></i> Vincular y Procesar';
                        btn.disabled = false;
                        btn.classList.remove('opacity-75');
                    }
                    if (fileInput) fileInput.value = null;
                    updateFileName();
                };

                // Event Listeners for Visor
                document.getElementById('schedule-filter-type')?.addEventListener('change', fillTargetSelect);
                document.getElementById('schedule-filter-target')?.addEventListener('change', loadSchedule);
                document.getElementById('schedule-filter-type')?.addEventListener('change', fillTargetSelect);
                document.getElementById('schedule-filter-target')?.addEventListener('change', loadSchedule);
                // document.getElementById('schedule-week')?.addEventListener('change', loadSchedule); // Eliminado

                // Default dates for schedule visor (Current Monday to Friday)
                const now = new Date();
                const day = now.getDay() || 7;
                const mon = new Date(now); mon.setDate(now.getDate() - day + 1);
                const fri = new Date(mon); fri.setDate(mon.getDate() + 4);

                if (document.getElementById('schedule-start-date'))
                    document.getElementById('schedule-start-date').value = mon.toISOString().split('T')[0];
                if (document.getElementById('schedule-end-date'))
                    document.getElementById('schedule-end-date').value = fri.toISOString().split('T')[0];

                // Initial Loads
                loadConfig('recess');
                loadConfig('lunch');
                loadCatalogs();
                loadObsTeacherList();



                // --- Visor de Horarios Logic ---

                function getFactorMinutes(subject) {
                    if (!subject) return 0;
                    const match = subject.match(/\(F\+(\d+)\)/);
                    return match ? parseInt(match[1]) : 0;
                }

                function getCalculatedTime(startTime, endTime, subject) {
                    const factorMins = getFactorMinutes(subject);
                    if (factorMins === 0) return `${startTime.substring(0, 5)} - ${endTime.substring(0, 5)}`;

                    const [h, m] = endTime.split(':').map(Number);
                    const date = new Date();
                    date.setHours(h, m, 0);
                    date.setMinutes(date.getMinutes() + factorMins);

                    const newEnd = `${String(date.getHours()).padStart(2, '0')}:${String(date.getMinutes()).padStart(2, '0')}`;
                    return `${startTime.substring(0, 5)} - ${newEnd}`;
                }

                function cleanCycleName(name) {
                    if (!name) return "";
                    return name.replace(/\s*\([^)]*\)$/, '').trim();
                }

                function getCourseColor(subject, type) {
                    if (type !== 'classroom') return 'bg-indigo-50 border-indigo-200 text-indigo-900 hover:border-indigo-300';

                    const s = subject.toUpperCase();
                    const math = ['ALGEBRA', 'GEOMETRIA', 'RAZ. MATEMATICO', 'ARITMETICA', 'TRIGONOMETRIA', 'RAZONAMIENTO MATEMATICO'];
                    const letters = ['LENGUAJE', 'LITERATURA', 'FILOSOFIA', 'INGLES', 'HISTORIA', 'PSICOLOGIA', 'CIVICA'];
                    const science = ['BIOLOGIA', 'QUIMICA', 'FISICA', 'GEOGRAFIA'];

                    if (math.some(m => s.includes(m))) return 'bg-blue-50 border-blue-200 text-blue-900 hover:border-blue-300';
                    if (letters.some(l => s.includes(l))) return 'bg-orange-50 border-orange-200 text-orange-900 hover:border-orange-300';
                    if (science.some(sci => s.includes(sci))) return 'bg-green-50 border-green-200 text-green-900 hover:border-green-300';

                    return 'bg-slate-50 border-slate-200 text-slate-900 hover:border-slate-300';
                }

                async function loadCatalogs() {
                    try {
                        const tRes = await authFetch(`${window.CONFIG.BASE_URL}/api/schedule/teachers`);
                        const tData = await tRes.json();
                        if (tData.success) teachersData = tData.data;

                        const cRes = await authFetch(`${window.CONFIG.BASE_URL}/api/schedule/classes`);
                        const cData = await cRes.json();
                        if (cData.success) classesData = cData.data;

                        fillTargetSelect();
                    } catch (e) { console.error("Error loading catalogs:", e); }
                }

                function fillTargetSelect() {
                    const type = document.getElementById('schedule-filter-type').value;
                    const target = document.getElementById('schedule-filter-target');
                    if (!target) return;
                    target.innerHTML = '';

                    let data = type === 'teacher' ? teachersData : classesData;

                    // Debugging Ajuste 3: 
                    console.log(`POBLANDO SELECT (${type}):`, data);

                    data.forEach(item => {
                        let opt = document.createElement('option');
                        opt.value = item.id;

                        // AJUSTE 3: Mapeo correcto para docentes (last_name, first_name)
                        if (type === 'teacher') {
                            opt.textContent = `${item.last_name || ''}, ${item.first_name || ''}`.trim() || `ID: ${item.id}`;
                        } else {
                            opt.textContent = item.name || `Aula ${item.id}`;
                        }

                        target.appendChild(opt);
                    });

                    if (data.length > 0) loadSchedule();
                }

                async function loadSchedule() {
                    const type = document.getElementById('schedule-filter-type').value;
                    const targetId = document.getElementById('schedule-filter-target').value;
                    const sDate = document.getElementById('schedule-start-date').value;
                    const eDate = document.getElementById('schedule-end-date').value;

                    if (!targetId || !sDate || !eDate) return;

                    const endpoint = type === 'teacher'
                        ? `${window.CONFIG.BASE_URL}/api/schedule/teacher/${targetId}?start_date=${sDate}&end_date=${eDate}`
                        : `${window.CONFIG.BASE_URL}/api/schedule/classroom/${targetId}?start_date=${sDate}&end_date=${eDate}`;

                    try {
                        const res = await authFetch(endpoint);
                        const data = await res.json();
                        if (data.success) {
                            renderScheduleGrid(data.data, new Date(sDate + 'T00:00:00'));
                        }
                    } catch (e) { console.error("Error loading schedule:", e); }
                }

                async function exportSchedule() {
                    const type = document.getElementById('schedule-filter-type').value;
                    const targetId = document.getElementById('schedule-filter-target').value;
                    const sDate = document.getElementById('schedule-start-date').value;
                    const eDate = document.getElementById('schedule-end-date').value;

                    if (!targetId || !sDate || !eDate) return alert("Por favor selecciona los filtros primero antes de exportar.");

                    const btn = document.getElementById('export-excel-btn');
                    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Generando...';
                    btn.disabled = true;

                    try {
                        const endpoint = `${window.CONFIG.BASE_URL}/api/schedule/export?type=${type}&target_id=${targetId}&start_date=${sDate}&end_date=${eDate}`;

                        const res = await authFetch(endpoint);
                        if (!res.ok) {
                            const errorData = await res.json();
                            throw new Error(errorData.detail || "Error al exportar");
                        }

                        const blob = await res.blob();
                        const url = window.URL.createObjectURL(blob);
                        const a = document.createElement('a');
                        a.style.display = 'none';
                        a.href = url;

                        const todayStr = new Date().toISOString().slice(0, 10).replace(/-/g, "");
                        a.download = `horarios_export_${todayStr}.xlsx`;
                        document.body.appendChild(a);
                        a.click();
                        window.URL.revokeObjectURL(url);
                        document.body.removeChild(a);

                    } catch (e) {
                        alert("Error descargando el archivo Excel: " + e.message);
                    } finally {
                        btn.innerHTML = '<i class="fa-solid fa-download"></i> Exportar a Excel';
                        btn.disabled = false;
                    }
                }

                function renderScheduleGrid(sessions, mondayDate) {
                    const filterType = document.getElementById('schedule-filter-type');
                    if (!filterType) return;
                    const type = filterType.value;
                    const summaryPanel = document.getElementById('schedule-teacher-summary');

                    if (type === 'teacher') {
                        if (summaryPanel) summaryPanel.classList.remove('hidden');
                        renderTeacherAgenda(sessions, mondayDate);
                    } else {
                        if (summaryPanel) summaryPanel.classList.add('hidden');
                        renderClassroomCalendar(sessions, mondayDate);
                    }
                }

                function renderTeacherAgenda(sessions, startDate) {
                    const tbody = document.getElementById('schedule-grid-body');
                    const hourHeader = document.getElementById('schedule-header-hour');
                    if (hourHeader) hourHeader.classList.add('hidden');

                    if (!tbody) return;
                    tbody.innerHTML = '';

                    if (!sessions || sessions.length === 0) {
                        tbody.innerHTML = `<tr class="border-b border-slate-200"><td colspan="5" class="p-12 text-center text-slate-400 font-medium italic">No hay clases programadas para este docente en el rango seleccionado.</td></tr>`;
                        document.getElementById('sch-summary-name').innerText = "Sin Datos";
                        document.getElementById('sch-summary-range').innerText = "---";
                        document.getElementById('sch-summary-hours').innerText = "0.00";
                        document.getElementById('sch-summary-breaks').innerText = "0";
                        return;
                    }

                    // Inject Breaks (si aplica, manteniendo lógica legacy)
                    injectBreaks(sessions, startDate, true);

                    // Group by Day (Dynamic Range)
                    const daysInRange = [];
                    let curr = new Date(startDate);
                    const endDateStr = document.getElementById('schedule-end-date').value;
                    const endDate = new Date(endDateStr + 'T00:00:00');

                    while (curr <= endDate) {
                        daysInRange.push(curr.toISOString().split('T')[0]);
                        curr.setDate(curr.getDate() + 1);
                        if (daysInRange.length > 31) break; // Safety cap
                    }

                    let totalHours = 0;
                    let totalBreaks = 0;
                    let teacherName = "";

                    const grouped = {};
                    daysInRange.forEach(d => grouped[d] = []);

                    sessions.forEach(s => {
                        if (grouped[s.date]) grouped[s.date].push(s);
                        if (!s.is_break && !teacherName) {
                            // Si es reemplazo, no tomamos el nombre del titular para el resumen
                            // pero rpt tiene el nombre del docente que buscamos
                        }
                    });

                    // Re-fetch clean teacher name from select if empty
                    const targetSelect = document.getElementById('schedule-filter-target');
                    teacherName = targetSelect.options[targetSelect.selectedIndex]?.text || "Docente";

                    // Calculate Totals using Backend Logic Sync
                    sessions.forEach(s => {
                        if (!s.is_break) {
                            totalHours += (s.horas_dictadas || 0);
                            if ((s.receso || 0) > 0) totalBreaks += 1; // CONTEO, no suma
                        }
                    });

                    if (document.getElementById('sch-summary-name')) document.getElementById('sch-summary-name').innerText = teacherName;

                    const moStr = new Date(startDate).toLocaleDateString('es-ES', { day: '2-digit', month: 'short' });
                    const frStr = endDate.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
                    if (document.getElementById('sch-summary-range')) document.getElementById('sch-summary-range').innerText = `${moStr} - ${frStr}`;
                    if (document.getElementById('sch-summary-hours')) document.getElementById('sch-summary-hours').innerText = totalHours.toFixed(2);
                    if (document.getElementById('sch-summary-breaks')) document.getElementById('sch-summary-breaks').innerText = totalBreaks.toString();

                    const tr = document.createElement('tr');
                    tr.className = "align-top";

                    daysInRange.forEach(dateStr => {
                        const td = document.createElement('td');
                        td.className = "p-3 border-r border-slate-200 min-w-[220px] bg-slate-50/10";

                        const daySessions = grouped[dateStr].sort((a, b) => (a.start_time || "").localeCompare(b.start_time || ""));

                        let html = "";
                        daySessions.forEach(s => {
                            const timeRange = getCalculatedTime(s.start_time, s.end_time, s.subject || "");
                            const cleanedSubject = s.is_break ? (s.subject || "RECESO") : (s.subject || "").replace(/\s*\([^)]*\)$/, '').trim();

                            if (s.is_break) {
                                const isLunch = s.category === 'lunch';
                                html += `
                            <div class="mb-3 bg-amber-50 border border-amber-200 rounded-xl p-3 flex flex-col items-center justify-center text-center shadow-sm animate-in fade-in zoom-in duration-300">
                                <div class="text-amber-600 text-lg mb-1"><i class="fa-solid fa-${isLunch ? 'utensils' : 'mug-hot'}"></i></div>
                                <div class="font-black text-[10px] text-amber-900 uppercase tracking-widest">${cleanedSubject}</div>
                                <div class="text-[9px] font-bold text-amber-700/60 mt-0.5">${timeRange}</div>
                            </div>
                        `;
                            } else {
                                // AJUSTE 1: Estilo distintivo para reemplazos
                                let cardColor = getCourseColor(s.subject, 'teacher');
                                let replBadge = "";
                                if (s.is_replacement) {
                                    cardColor = "bg-orange-50 border-orange-300 text-orange-900 hover:border-orange-400";
                                    replBadge = `
                                <div class="mt-2 py-1 px-2 bg-orange-200/50 rounded-lg text-[9px] font-black text-orange-800 uppercase tracking-tighter">
                                    <i class="fa-solid fa-people-arrows"></i> REEMPLAZO (Titular: ${s.titular_name})
                                </div>
                            `;
                                }

                                const groupName = cleanCycleName(s.class_group);
                                const sedeName = s.sede || "S/S";
                                const tooltip = `Curso: ${s.subject}\nHora: ${timeRange}\nAula: ${s.class_group}\nSede: ${sedeName}`;

                                html += `
                            <div title="${tooltip}" class="mb-3 ${cardColor} border rounded-xl p-4 shadow-sm flex flex-col items-center justify-center text-center transition-all hover:scale-105 hover:shadow-lg hover:z-10 cursor-default group border-b-4">
                                <div class="font-black text-sm leading-tight uppercase tracking-tight text-slate-900">${cleanedSubject}</div>
                                <div class="text-[11px] font-bold text-slate-600 mt-2 bg-white/50 px-3 py-1 rounded-full"><i class="fa-regular fa-clock mr-1"></i> ${timeRange}</div>
                                
                                <div class="mt-2 flex flex-col items-center gap-1">
                                    <div class="text-[10px] font-black flex items-center justify-center gap-1 uppercase tracking-tighter opacity-60">
                                        <i class="fa-solid fa-layer-group"></i> ${groupName}
                                    </div>
                                    <div class="text-[9px] font-bold flex items-center justify-center gap-1 uppercase tracking-widest text-indigo-600/70">
                                        <i class="fa-solid fa-location-dot"></i> ${sedeName}
                                    </div>
                                </div>

                                ${replBadge}
                            </div>
                        `;
                            }
                        });

                        if (daySessions.length === 0) {
                            html = `<div class="h-64 flex items-center justify-center text-slate-300 italic text-xs uppercase tracking-widest">Sin Actividad</div>`;
                        }

                        td.innerHTML = html;
                        tr.appendChild(td);
                    });

                    tbody.appendChild(tr);

                    // Update Headers (Dynamic Day Names)
                    const thead = document.querySelector('#schedule thead tr');
                    if (thead) {
                        // Keep the first th (Horario header) if classroom view, but in teacher agenda it's hidden
                        thead.innerHTML = '';
                        if (!hourHeader.classList.contains('hidden')) {
                            thead.appendChild(hourHeader);
                        }

                        daysInRange.forEach(d => {
                            const dateObj = new Date(d + 'T00:00:00');
                            const dayName = dateObj.toLocaleDateString('es-ES', { weekday: 'short' }).toUpperCase();
                            const dayNum = dateObj.getDate();
                            const monthName = dateObj.toLocaleDateString('es-ES', { month: 'short' }).toUpperCase();

                            const th = document.createElement('th');
                            th.className = "px-4 py-3 border-r border-slate-200 text-center tracking-wider bg-slate-100 min-w-[220px]";
                            th.innerHTML = `
                        <div class="flex flex-col items-center">
                            <span class="text-[10px] font-black tracking-widest text-slate-400">${dayName}</span>
                            <span class="text-lg font-black text-slate-800">${dayNum}</span>
                            <span class="text-[9px] font-bold opacity-50 uppercase">${monthName}</span>
                        </div>
                    `;
                            thead.appendChild(th);
                        });
                    }
                }

                function renderClassroomCalendar(sessions, startDate) {
                    const tbody = document.getElementById('schedule-grid-body');
                    const hourHeader = document.getElementById('schedule-header-hour');
                    if (hourHeader) hourHeader.classList.remove('hidden');

                    if (!tbody) return;
                    tbody.innerHTML = '';
                    if (!sessions || sessions.length === 0) {
                        tbody.innerHTML = `<tr class="border-b border-slate-200"><td colspan="6" class="p-12 text-center text-slate-400 font-medium italic">No hay clases programadas para esta aula.</td></tr>`;
                        return;
                    }

                    // Inject Breaks
                    injectBreaks(sessions, startDate, false);

                    const timeBlocks = {};
                    sessions.forEach(s => {
                        if (!timeBlocks[s.start_time]) {
                            timeBlocks[s.start_time] = { start_time: s.start_time, end_time: s.end_time, is_break: s.is_break, days: {} };
                        }
                        timeBlocks[s.start_time].days[s.date] = s;
                    });

                    const sortedStartTimes = Object.keys(timeBlocks).sort();

                    const daysInRange = [];
                    let curr = new Date(startDate);
                    const endDate = new Date(document.getElementById('schedule-end-date').value + 'T00:00:00');
                    while (curr <= endDate) {
                        daysInRange.push(curr.toISOString().split('T')[0]);
                        curr.setDate(curr.getDate() + 1);
                        if (daysInRange.length > 31) break;
                    }

                    sortedStartTimes.forEach(time => {
                        const block = timeBlocks[time];
                        const tr = document.createElement('tr');

                        if (block.is_break) {
                            const firstSession = Object.values(block.days)[0];
                            const isLunch = firstSession.category === 'lunch';
                            const icon = isLunch ? 'utensils' : 'mug-hot';
                            const label = firstSession.subject || (isLunch ? 'Almuerzo' : 'Receso');
                            const bgColor = isLunch ? 'bg-slate-100/80' : 'bg-amber-50/50';
                            const textColor = isLunch ? 'text-slate-500' : 'text-amber-900';

                            tr.className = `${bgColor} border-b border-slate-200`;
                            tr.innerHTML = `
                        <td class="px-2 py-1.5 text-center border-r border-slate-200 ${textColor}">
                            <div class="font-bold text-xs">${block.start_time}</div>
                            <div class="text-[10px] opacity-70">${block.end_time}</div>
                        </td>
                        <td colspan="${daysInRange.length}" class="py-2 text-center ${textColor} font-black tracking-[0.2em] uppercase text-[10px] flex items-center justify-center gap-2">
                            <i class="fa-solid fa-${icon}"></i> ${label}
                        </td>
                    `;
                        } else {
                            tr.className = "border-b border-slate-200";
                            let rowHtml = `
                        <td class="px-2 py-2 font-black text-slate-800 text-center border-r border-slate-200 bg-slate-50/50">
                            <div class="text-sm">${block.start_time}</div>
                            <div class="text-[10px] text-slate-400 font-bold">${block.end_time}</div>
                        </td>
                    `;

                            daysInRange.forEach(dateStr => {
                                const session = block.days[dateStr];
                                if (session && !session.is_break && session.subject) {
                                    const subLabel = session.teacher || "Sin Docente";
                                    const cardColor = getCourseColor(session.subject, 'classroom');
                                    const timeRange = getCalculatedTime(session.start_time, session.end_time, session.subject);
                                    const tooltip = `Curso: ${session.subject}\nHora: ${timeRange}\nDocente: ${session.teacher}`;

                                    rowHtml += `
                            <td class="p-1 border-r border-slate-200 align-middle h-20">
                                <div title="${tooltip}" class="${cardColor} border rounded-lg p-2 shadow-sm h-full flex flex-col items-center justify-center text-center transition-all hover:scale-105 hover:shadow-lg hover:z-10 cursor-default">
                                    <div class="font-black text-[10px] leading-tight uppercase tracking-tighter">${session.subject}</div>
                                    <div class="text-[9px] font-bold opacity-80 mt-1">${timeRange}</div>
                                    <div class="text-[8px] font-black mt-1 uppercase tracking-tighter opacity-60 truncate w-full">${subLabel}</div>
                                </div>
                            </td>
                            `;
                                } else {
                                    rowHtml += `<td class="p-1 border-r border-slate-200 bg-slate-50/20"></td>`;
                                }
                            });
                            tr.innerHTML = rowHtml;
                        }
                        tbody.appendChild(tr);
                    });

                    const theadRows = document.querySelector('#schedule thead tr');
                    if (theadRows) {
                        theadRows.innerHTML = '';
                        if (hourHeader) theadRows.appendChild(hourHeader);

                        daysInRange.forEach(d => {
                            const dateObj = new Date(d + 'T00:00:00');
                            const th = document.createElement('th');
                            th.className = "px-4 py-3 border-r border-slate-200 text-center tracking-wider bg-slate-100 min-w-[150px]";
                            th.innerHTML = `
                        <div class="flex flex-col items-center">
                            <span class="text-xs font-black tracking-widest text-slate-500">${dateObj.toLocaleDateString('es-ES', { weekday: 'short' }).toUpperCase()}</span>
                            <span class="text-lg font-black text-slate-800">${dateObj.getDate()}</span>
                        </div>
                    `;
                            theadRows.appendChild(th);
                        });
                    }
                }

                function injectBreaks(sessions, startDate, isTeacherView) {
                    let minStart = "23:59";
                    let maxEnd = "00:00";
                    sessions.forEach(s => {
                        if (s.start_time < minStart) minStart = s.start_time;
                        if (s.end_time > maxEnd) maxEnd = s.end_time;
                    });

                    const allConfigs = [
                        ...currentConfigs.recess.map(r => ({ ...r, category: 'recess' })),
                        ...currentConfigs.lunch.map(l => ({ ...l, category: 'lunch' }))
                    ];

                    const datesInRange = [];
                    let curr = new Date(startDate);
                    const endDate = new Date(document.getElementById('schedule-end-date').value + 'T00:00:00');
                    while (curr <= endDate) {
                        datesInRange.push(curr.toISOString().split('T')[0]);
                        curr.setDate(curr.getDate() + 1);
                        if (datesInRange.length > 31) break;
                    }

                    allConfigs.forEach(conf => {
                        const bStart = conf.start_time.substring(0, 5);
                        const bEnd = conf.end_time.substring(0, 5);
                        if (bStart < minStart || bEnd > maxEnd) return;

                        const hasCollision = sessions.some(s => {
                            if (s.is_break) return false;
                            return bStart < s.end_time && s.start_time < bEnd;
                        });

                        if (!hasCollision) {
                            datesInRange.forEach(dateStr => {
                                sessions.push({
                                    date: dateStr,
                                    start_time: bStart,
                                    end_time: bEnd,
                                    subject: "RECESO",
                                    is_break: true,
                                    category: conf.category
                                });
                            });
                        }
                    });
                }

                // --- Observations Module Logic ---
                function toggleObsTab(tabName) {
                    const regTab = document.getElementById('obs-tab-register');
                    const logsTab = document.getElementById('obs-tab-logs');
                    const regBtn = document.getElementById('tab-btn-register');
                    const logsBtn = document.getElementById('tab-btn-logs');

                    if (tabName === 'register') {
                        regTab.classList.remove('hidden');
                        logsTab.classList.add('hidden');
                        regBtn.className = "px-8 py-4 text-sm font-black border-b-2 border-indigo-600 text-indigo-600 transition-all uppercase tracking-widest";
                        logsBtn.className = "px-8 py-4 text-sm font-black border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all uppercase tracking-widest";
                    } else {
                        regTab.classList.add('hidden');
                        logsTab.classList.remove('hidden');
                        logsBtn.className = "px-8 py-4 text-sm font-black border-b-2 border-indigo-600 text-indigo-600 transition-all uppercase tracking-widest";
                        regBtn.className = "px-8 py-4 text-sm font-black border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all uppercase tracking-widest";
                        loadObsLogs();
                    }
                }

                async function loadObsTeacherList() {
                    const select = document.getElementById('obs-filter-docente');
                    const datalist = document.getElementById('teachers-datalist');
                    if (!select) return;
                    try {
                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/schedule/teachers`);
                        const json = await res.json();
                        const teachers = json.data || [];

                        // Fill the filter select
                        select.innerHTML = '<option value="">Selecciona un docente...</option>';

                        // Fill the datalist for replacement autocomplete
                        if (datalist) datalist.innerHTML = '';

                        teachers.forEach(t => {
                            const fullName = `${t.last_name || ''}, ${t.first_name || ''}`.trim() || `Docente ${t.id}`;

                            const opt = document.createElement('option');
                            opt.value = t.id;
                            opt.textContent = fullName;
                            select.appendChild(opt);

                            if (datalist) {
                                const dOpt = document.createElement('option');
                                dOpt.value = fullName;
                                // Store the ID in a data attribute to retrieve it later
                                dOpt.setAttribute('data-id', t.id);
                                datalist.appendChild(dOpt);
                            }
                        });
                    } catch (e) {
                        console.error("Error loading teachers for obs:", e);
                        select.innerHTML = '<option value="">Error al cargar</option>';
                    }
                }

                async function searchClassesForObs() {
                    console.log("Iniciando búsqueda de clases para el docente...");
                    const selDoc = document.getElementById('obs-filter-docente');
                    const teacherId = selDoc.value;
                    const teacherName = selDoc.options[selDoc.selectedIndex]?.text || "Docente";
                    const dateStart = document.getElementById('obs-date-start').value;
                    const dateEnd = document.getElementById('obs-date-end').value;
                    const tbody = document.getElementById('obs-search-body');

                    if (!teacherId || !dateStart || !dateEnd) {
                        alert("Por favor completa todos los filtros de búsqueda (Docente, Fecha Inicio y Fin).");
                        return;
                    }

                    console.log(`Buscando clases para ID: ${teacherId} (${teacherName}) del ${dateStart} al ${dateEnd}`);
                    tbody.innerHTML = '<tr><td colspan="5" class="px-4 py-12 text-center text-slate-400"><i class="fa-solid fa-spinner fa-spin text-xl mb-2"></i> Buscando clases...</td></tr>';

                    try {
                        const url = `${window.CONFIG.BASE_URL}/api/schedule/sessions-for-obs?teacher_id=${teacherId}&start_date=${dateStart}&end_date=${dateEnd}`;
                        const res = await authFetch(url);
                        if (!res.ok) {
                            const errorData = await res.json();
                            throw new Error(errorData.detail || `Error HTTP: ${res.status}`);
                        }

                        const json = await res.json();
                        const sessions = json.data || [];
                        console.log("Sesiones encontradas:", sessions.length);

                        tbody.innerHTML = '';
                        if (sessions.length === 0) {
                            tbody.innerHTML = '<tr><td colspan="5" class="px-4 py-12 text-center text-slate-400 italic">No se encontraron clases en este rango para este docente.</td></tr>';
                            return;
                        }

                        sessions.forEach(s => {
                            const tr = document.createElement('tr');
                            // Usamos session_ids para bloques agrupados
                            const sids = (s.session_ids || [s.id]).join(',');
                            tr.setAttribute('data-session-ids', sids);
                            tr.className = "hover:bg-slate-50 transition-colors border-b border-slate-100 group";

                            const sessionData = {
                                ...s,
                                docente_name: teacherName,
                                teacher_id: teacherId
                            };

                            // Renderizar etiqueta si ya existen incidencias
                            let statusBadge = '';
                            const hasObs = s.badge && s.badge !== 'INGRESAR';

                            if (hasObs) {
                                let badgeColor = 'bg-rose-50 text-rose-700 border-rose-200'; // Default FALTA (Rose)
                                if (s.badge === 'REEMPLAZO') {
                                    badgeColor = 'bg-amber-50 text-amber-700 border-amber-200'; // REEMPLAZO (Amber)
                                } else if (s.badge === 'FALTA/REEMP') {
                                    badgeColor = 'bg-indigo-50 text-indigo-700 border-indigo-200'; // MIXTA (Indigo)
                                }

                                statusBadge = `
                            <span class="${badgeColor} px-2 py-0.5 rounded-lg text-[9px] font-black uppercase tracking-tighter border shadow-sm ml-2">
                                <i class="fa-solid fa-circle-check mr-1 text-[8px]"></i> ${s.badge}
                            </span>
                        `;
                            }

                            // BUG 4: Si tiene incidencia, mostramos badge en lugar de botón
                            let actionHtml = `
                        <button onclick='openRegisterObsModal(${JSON.stringify(sessionData).replace(/'/g, "&apos;")}, this.closest("tr"))' class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest transition-all hover:scale-105 active:scale-95 shadow-md hover:shadow-indigo-200">
                            Registrar
                        </button>
                    `;

                            if (hasObs) {
                                actionHtml = statusBadge; // Reemplazamos botón por el badge
                                statusBadge = ''; // No duplicar arriba
                            }

                            tr.innerHTML = `
                        <td class="px-4 py-4 font-bold text-slate-800 whitespace-nowrap">${s.date} ${statusBadge}</td>
                        <td class="px-4 py-4">${s.subject || '---'}</td>
                        <td class="px-4 py-4"><span class="bg-slate-100 px-2 py-1 rounded text-xs font-bold uppercase">${s.class_group || '---'}</span></td>
                        <td class="px-4 py-4 font-mono text-xs text-slate-500">${s.start_time.substring(0, 5)} - ${s.end_time.substring(0, 5)}</td>
                        <td class="px-4 py-4 text-right action-cell">
                            ${actionHtml}
                        </td>
                    `;
                            tbody.appendChild(tr);
                        });
                    } catch (e) {
                        console.error("Error searching classes:", e);
                        tbody.innerHTML = `<tr><td colspan="5" class="px-4 py-12 text-center text-rose-500 font-bold">Error al buscar clases: ${e.message}</td></tr>`;
                    }
                }

                let currentSessionForObs = null;
                let currentRowElementForObs = null; // Bug 1 fix: referencia directa al <tr>

                function openRegisterObsModal(session, rowElement) {
                    currentSessionForObs = session;
                    currentRowElementForObs = rowElement || null; // guardar referencia directa al DOM
                    document.getElementById('obs-form-session-id').value = session.id;
                    document.getElementById('obs-form-teacher-id').value = session.teacher_id;
                    document.getElementById('obs-modal-teacher-name').innerText = session.docente_name || "Docente";
                    document.getElementById('obs-modal-date').innerText = `${session.date} (${session.start_time.substring(0, 5)} - ${session.end_time.substring(0, 5)})`;

                    // Reset form
                    document.querySelector('input[name="obs-block-mode"][value="full"]').checked = true;
                    document.getElementById('obs-form-type').value = 'FALTA';
                    document.getElementById('obs-form-discount').value = 'SIMPLE';
                    document.getElementById('obs-form-replacement-last').value = '';
                    document.getElementById('obs-form-replacement-first').value = '';
                    document.getElementById('obs-form-description').value = '';

                    toggleObsBlockMode(true);
                    document.getElementById('obs-register-modal').classList.remove('hidden');
                function handleObsTypeChange() {
                    const type = document.getElementById('obs-form-type').value;
                    const replContainer = document.getElementById('obs-replacement-fields');
                    if (!replContainer) return;

                    if (type === 'REEMPLAZO') {
                        replContainer.classList.remove('hidden');
                    } else {
                        replContainer.classList.add('hidden');
                    }
                }

                function toggleObsBlockMode(isFull) {
                    const singleCont = document.getElementById('obs-single-mode-container');
                    const splitCont = document.getElementById('obs-split-mode-container');

                    if (isFull) {
                        singleCont.classList.remove('hidden');
                        splitCont.classList.add('hidden');
                        handleObsTypeChange();
                    } else {
                        singleCont.classList.add('hidden');
                        splitCont.classList.remove('hidden');
                        renderPedagogicalSlots();
                    }
                }

                function renderPedagogicalSlots() {
                    const container = document.getElementById('obs-split-mode-container');
                    if (!currentSessionForObs) return;

                    const start = currentSessionForObs.start_time;
                    const end = currentSessionForObs.end_time;

                    // Generate 50 min slots
                    const slots = splitIntoPedagogicalHours(start, end);

                    container.innerHTML = `<p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Desglose de Bloque: ${slots.length} horas pedagógicas</p>`;

                    slots.forEach((slot, idx) => {
                        const slotDiv = document.createElement('div');
                        slotDiv.className = "bg-white border border-slate-200 rounded-xl p-4 shadow-sm space-y-3";
                        slotDiv.innerHTML = `
                    <div class="flex justify-between items-center">
                        <span class="text-xs font-black text-indigo-600 bg-indigo-50 px-2 py-1 rounded">Hora ${idx + 1}: ${slot.start} - ${slot.end}</span>
                        <select class="obs-slot-type text-[10px] font-bold border-none bg-slate-100 rounded-md px-2 py-1 focus:ring-0" onchange="toggleSlotReplacement(${idx}, this.value)">
                            <option value="NINGUNA">SIN INCIDENCIA</option>
                            <option value="FALTA" selected>FALTA</option>
                            <option value="REEMPLAZO">REEMPLAZO</option>
                        </select>
                    </div>
                    <div id="slot-replacement-container-${idx}" class="hidden mt-2 pt-2 border-t border-slate-100">
                        <div class="grid grid-cols-2 gap-3">
                            <input type="text" class="obs-slot-replacement-last w-full px-3 py-2 bg-amber-50 border border-amber-100 rounded-lg text-xs font-medium placeholder:text-amber-400 focus:bg-white" list="teachers-datalist" placeholder="Apellidos...">
                            <input type="text" class="obs-slot-replacement-first w-full px-3 py-2 bg-amber-50 border border-amber-100 rounded-lg text-xs font-medium placeholder:text-amber-400 focus:bg-white" placeholder="Nombres...">
                        </div>
                    </div>
                    <input type="hidden" class="obs-slot-start" value="${slot.start}">
                    <input type="hidden" class="obs-slot-end" value="${slot.end}">
                `;
                        container.appendChild(slotDiv);
                    });
                }

                function toggleSlotReplacement(idx, value) {
                    const container = document.getElementById(`slot-replacement-container-${idx}`);
                    if (value === 'REEMPLAZO') container.classList.remove('hidden');
                    else container.classList.add('hidden');
                }

                function splitIntoPedagogicalHours(startTime, endTime) {
                    const parse = t => {
                        const [h, m] = t.split(':').map(Number);
                        return h * 60 + m;
                    };
                    const format = m => {
                        const h = Math.floor(m / 60);
                        const mins = m % 60;
                        return `${String(h).padStart(2, '0')}:${String(mins).padStart(2, '0')}`;
                    };

                    const startMins = parse(startTime);
                    const endMins = parse(endTime);
                    const totalMins = endMins - startMins;

                    const slots = [];
                    let current = startMins;

                    while (current < endMins) {
                        let next = current + 50;
                        if (next > endMins) next = endMins;

                        // If the remaining time is very small (e.g. 5-10 mins), merge it with the last slot
                        // to avoid tiny fragments. But typically blocks are multiples of 50.
                        if (endMins - next < 15 && endMins - next > 0) {
                            next = endMins;
                        }

                        slots.push({ start: format(current), end: format(next) });
                        current = next;
                    }
                    return slots;
                }

                function closeObsRegisterModal() {
                    document.getElementById('obs-register-modal').classList.add('hidden');
                }

                async function saveObservation() {
                    // Check granular permission 'crear_observaciones'
                    if (!global.hasPermission('crear_observaciones')) {
                        alert("No tienes permiso 'crear_observaciones'");
                        return;
                    }
                    const isFullBlock = document.querySelector('input[name="obs-block-mode"]:checked').value === 'full';
                    // Leer directamente del objeto en memoria para garantizar el tipo correcto
                    const sessionId = currentSessionForObs ? currentSessionForObs.id : null;
                    const teacherId = currentSessionForObs ? currentSessionForObs.teacher_id : null;

                    let payloads = [];

                    if (isFullBlock) {
                        const type = document.getElementById('obs-form-type').value;
                        const discount = document.getElementById('obs-form-discount').value;
                        const replLast = document.getElementById('obs-form-replacement-last').value;
                        const replFirst = document.getElementById('obs-form-replacement-first').value;
                        const description = document.getElementById('obs-form-description').value;

                        let replId = null;
                        if (type === 'REEMPLAZO') {
                            const datalist = document.getElementById('teachers-datalist');
                            const fullInput = `${replLast}, ${replFirst}`.trim();
                            const matched = Array.from(datalist.options).find(o => o.value === fullInput);
                            if (matched) replId = parseInt(matched.getAttribute('data-id'));
                        }

                        const sessionIds = currentSessionForObs.session_ids || [sessionId];

                        sessionIds.forEach(sid => {
                            payloads.push({
                                session_id: sid,
                                teacher_id: teacherId,
                                type: type,
                                discount_type: discount,
                                replacement_last_name: type === 'REEMPLAZO' ? replLast : null,
                                replacement_first_name: type === 'REEMPLAZO' ? replFirst : null,
                                description: description,
                                start_time: currentSessionForObs.start_time,
                                end_time: currentSessionForObs.end_time
                            });
                        });
                    } else {
                        const slotDivs = document.getElementById('obs-split-mode-container').querySelectorAll('.bg-white.border');
                        const mainDescription = "Registro desglosado por horas";

                        slotDivs.forEach((div, idx) => {
                            const type = div.querySelector('.obs-slot-type').value;
                            if (type === 'NINGUNA') return; // Skip hours with no incident

                            const replLast = div.querySelector('.obs-slot-replacement-last').value;
                            const replFirst = div.querySelector('.obs-slot-replacement-first').value;
                            const start = div.querySelector('.obs-slot-start').value;
                            const end = div.querySelector('.obs-slot-end').value;

                            let replId = null;
                            if (type === 'REEMPLAZO') {
                                const datalist = document.getElementById('teachers-datalist');
                                const fullInput = `${replLast}, ${replFirst}`.trim();
                                const matched = Array.from(datalist.options).find(o => o.value === fullInput);
                                if (matched) replId = parseInt(matched.getAttribute('data-id'));
                            }

                            payloads.push({
                                session_id: sessionId,
                                teacher_id: teacherId,
                                type: type,
                                discount_type: 'SIMPLE', // Default for split
                                replacement_last_name: type === 'REEMPLAZO' ? replLast : null,
                                replacement_first_name: type === 'REEMPLAZO' ? replFirst : null,
                                description: `${mainDescription} (Hora ${idx + 1})`,
                                start_time: start,
                                end_time: end
                            });
                        });
                    }

                    if (payloads.length === 0) {
                        alert("No hay incidencias para registrar.");
                        return;
                    }

                    // Guard: si session_id es null, la fila del RPT no tiene sesión en la BD
                    if (payloads.some(p => p.session_id === null || p.session_id === undefined)) {
                        alert("⚠️ Esta fila no tiene una sesión registrada en el sistema (session_id nulo).\n\nEsto ocurre cuando el bloque aparece en el RPT de planillas pero no fue importado en el módulo de Horarios. Por favor, verifica la importación del horario para este docente y fecha.");
                        return;
                    }

                    console.log("Enviando payloads:", payloads);

                    try {
                        // We send one by one as requested (multiples objetos)
                        const promises = payloads.map(p => authFetch(`${window.CONFIG.BASE_URL}/api/schedule/observations`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(p)
                        }));

                        const results = await Promise.all(promises);
                        const allOk = results.every(r => r.ok);

                        if (allOk) {
                            closeObsRegisterModal();

                            // Bug 1 fix: usar la referencia directa al <tr> guardada al abrir el modal
                            const row = currentRowElementForObs;
                            currentRowElementForObs = null; // limpiar para el próximo uso
                            if (row) {
                                const actionCell = row.querySelector('.action-cell');
                                if (actionCell) {
                                    const types = [...new Set(payloads.map(p => p.type))];
                                    const label = types.length > 1 ? 'FALTA/REEMP' : types[0];

                                    let badgeColor = 'bg-rose-50 text-rose-700 border-rose-200';
                                    if (label === 'REEMPLAZO') {
                                        badgeColor = 'bg-amber-50 text-amber-700 border-amber-200';
                                    } else if (label === 'FALTA/REEMP') {
                                        badgeColor = 'bg-indigo-50 text-indigo-700 border-indigo-200';
                                    }

                                    actionCell.innerHTML = `
                                <span class="${badgeColor} px-2 py-0.5 rounded-lg text-[9px] font-black uppercase tracking-tighter border shadow-sm animate-pulse">
                                    <i class="fa-solid fa-circle-check mr-1 text-[8px]"></i> ${label}
                                </span>
                            `;
                                }
                            } else {
                                searchClassesForObs();
                            }

                            document.getElementById('obs-confirm-modal').classList.remove('hidden');
                        } else {
                            alert("Algunas incidencias no pudieron registrarse. Revisa la consola.");
                        }
                    } catch (e) {
                        console.error("Error saving observations:", e);
                        alert("Error de conexión al guardar.");
                    }
                }

                function closeObsConfirmModal() {
                    document.getElementById('obs-confirm-modal').classList.add('hidden');
                }

                async function deleteObservation(obsId) {
                    if (!confirm("¿Estás seguro de que deseas eliminar esta incidencia? Esta acción no se puede deshacer de forma sencilla.")) return;

                    try {
                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/schedule/observations/${obsId}`, {
                            method: 'DELETE'
                        });
                        const data = await res.json();

                        if (data.success) {
                            alert("Incidencia eliminada con éxito.");
                            // Refrescar vistas
                            loadObsLogs();
                            if (document.getElementById('rpt-planilla-body').innerHTML !== '') {
                                loadRptPlanilla(rptCurrentPage);
                            }
                        } else {
                            alert("Error al eliminar: " + data.message);
                        }
                    } catch (e) {
                        console.error("Error deleting observation:", e);
                        alert("Error de conexión al eliminar.");
                    }
                }

                async function loadObsLogs() {
                    const tbody = document.getElementById('obs-logs-body');
                    if (!tbody) return;
                    tbody.innerHTML = '<tr><td colspan="7" class="px-4 py-12 text-center text-slate-400"><i class="fa-solid fa-spinner fa-spin text-xl mb-2"></i> Cargando logs...</td></tr>';

                    try {
                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/schedule/observations/logs`);
                        const json = await res.json();
                        const logs = json.data || [];

                        tbody.innerHTML = '';
                        if (logs.length === 0) {
                            tbody.innerHTML = '<tr><td colspan="7" class="px-4 py-12 text-center text-slate-400 italic">No hay registros de auditoría aún.</td></tr>';
                            return;
                        }

                        logs.forEach(l => {
                            const tr = document.createElement('tr');
                            tr.className = "hover:bg-slate-50 transition-colors border-b border-slate-100 last:border-0";

                            let typeBadge = '';
                            switch (l.type) {
                                case 'FALTA': typeBadge = '<span class="bg-rose-100 text-rose-700 px-2 py-1 rounded text-[10px] font-black underline">FALTA</span>'; break;
                                case 'REEMPLAZO': typeBadge = '<span class="bg-amber-100 text-amber-700 px-2 py-1 rounded text-[10px] font-black underline">REEMPLAZO</span>'; break;
                                case 'VACACIONES': typeBadge = '<span class="bg-indigo-100 text-indigo-700 px-2 py-1 rounded text-[10px] font-black underline">VACACIONES</span>'; break;
                                case 'DESCANSO_MEDICO': typeBadge = '<span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-[10px] font-black underline">DESC. MÉDICO</span>'; break;
                                default: typeBadge = `<span class="bg-slate-100 text-slate-700 px-2 py-1 rounded text-[10px] font-black">${l.type}</span>`;
                            }

                            tr.innerHTML = `
                        <td class="px-4 py-4 text-xs font-mono text-slate-500">${l.date_record}</td>
                        <td class="px-4 py-4 text-sm font-bold text-indigo-700">${l.user}</td>
                        <td class="px-4 py-4 text-sm text-slate-800">${l.teacher_affected}</td>
                        <td class="px-4 py-4">${typeBadge}</td>
                        <td class="px-4 py-4 text-xs text-slate-600">${l.class_date}</td>
                        <td class="px-4 py-4 text-xs italic text-slate-400 max-w-xs truncate" title="${l.description || ''}">${l.description || '---'}</td>
                        <td class="px-4 py-4 text-right">
                           <button onclick="deleteObservation(${l.id})" class="text-slate-300 hover:text-rose-600 transition-colors p-2" title="Eliminar Incidencia">
                               <i class="fa-solid fa-trash-can"></i>
                           </button>
                        </td>
                    `;
                            tbody.appendChild(tr);
                        });
                    } catch (e) {
                        console.error("Error loading obs logs:", e);
                        tbody.innerHTML = '<tr><td colspan="7" class="px-4 py-12 text-center text-rose-500 font-bold">Error al cargar el historial.</td></tr>';
                    }
                }

                function toggleConfigMenu() {
                    const submenu = document.getElementById('config-submenu');
                    const chevron = document.getElementById('config-chevron');
                    const isHidden = submenu.classList.contains('hidden');

                    if (isHidden) {
                        submenu.classList.remove('hidden');
                        chevron.classList.add('rotate-180');
                    } else {
                        submenu.classList.add('hidden');
                        chevron.classList.remove('rotate-180');
                    }
                }

                // ═══════════════════════════════════════════════
                //  MÓDULO DOCENTES — JavaScript v2
                // ═══════════════════════════════════════════════

                const IMP_PAGE_SIZE = 20;

                let maestraPage = 1, maestraTotalPages = 1;
                let lastMaestraData = []; // Cache de la página actual de la maestra
                let currentMergeData = []; // Docentes seleccionados para fusión
                let sinAsignarPage = 1, sinAsignarTotalPages = 1;
                let importAllRows = [];   // todos los rows del excel
                let importPage = 1, importTotalPages = 1;
                let lastConflicts = [];   // cache del último reprocesamiento


                function changeImportPage(delta) {
                    importPage = Math.max(1, Math.min(importTotalPages, importPage + delta));
                    renderImportPage();
                }

                // ── Tab Management ────────────────────────────────
                function toggleDocentesTab(tabId) {
                    console.log("🔄 Cambiando a pestaña Docentes:", tabId);
                    
                    const containers = {
                        'upload': 'doc-tab-upload-excel',
                        'maestra': 'doc-tab-maestra',
                        'sinasignar': 'doc-tab-sinasignar',
                        'conflictos': 'doc-tab-conflictos'
                    };

                    // Ocultar todos los contenedores de secciones
                    Object.values(containers).forEach(id => {
                        const el = document.getElementById(id);
                        if (el) el.classList.add('hidden');
                    });

                    // UI Buttons Reset: Quitamos estilos de activo de todos
                    document.querySelectorAll('.doc-tab-btn').forEach(btn => {
                        btn.classList.remove('border-indigo-600', 'text-indigo-600');
                        btn.classList.add('border-transparent', 'text-slate-400');
                    });

                    // Mostrar el contenedor seleccionado
                    const targetContainerId = containers[tabId];
                    if (targetContainerId) {
                        const targetEl = document.getElementById(targetContainerId);
                        if (targetEl) targetEl.classList.remove('hidden');
                    }

                    // Aplicar estilo activo al botón seleccionado (por ID o por selector)
                    const activeBtn = document.getElementById(`doc-tab-btn-${tabId}`);
                    if (activeBtn) {
                        activeBtn.classList.remove('border-transparent', 'text-slate-400');
                        activeBtn.classList.add('border-indigo-600', 'text-indigo-600');
                    }

                    // Carga de datos proactiva
                    if (tabId === 'maestra') loadMaestra(1);
                    if (tabId === 'sinasignar') loadSinAsignar(1);
                    if (tabId === 'conflictos') renderConflictos(lastConflicts);
                }

                async function uploadDocentesExcel() {
                    const input = document.getElementById('doc-excel-upload');
                    if (!input?.files?.length) { alert('Selecciona un archivo Excel'); return; }
                    const fd = new FormData();
                    fd.append('file', input.files[0]);
                    try {
                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/docentes/import-excel`, { method: 'POST', body: fd });
                        const data = await res.json();
                        if (!res.ok) { alert('Error: ' + (data.detail || 'Error desconocido')); return; }
                        document.getElementById('doc-imp-inserted').textContent = data.inserted;
                        document.getElementById('doc-imp-updated').textContent = data.updated;
                        document.getElementById('doc-imp-total').textContent = data.rows.length;
                        importAllRows = data.rows;
                        importPage = 1;
                        importTotalPages = Math.max(1, Math.ceil(importAllRows.length / IMP_PAGE_SIZE));
                        renderImportPage();
                        document.getElementById('doc-import-result').classList.remove('hidden');
                        alert(`✅ Importación: ${data.inserted} nuevos, ${data.updated} actualizados.`);
                    } catch (e) { alert('Error de conexión: ' + e.message); }
                }

                // ── Maestra ──────────────────────────────────────
                async function loadMaestra(page = 1) {
                    try {
                        console.log("🚀 Cargando MAESTRA...");
                        maestraPage = page;
                        const statusFilter = document.getElementById('doc-status-filter').value;
                        const search = encodeURIComponent(document.getElementById('doc-search').value.trim());

                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/docentes?status_filter=${statusFilter}&search=${search}&page=${page}&limit=20`);
                        console.log("📡 STATUS MAESTRA:", res.status);

                        const data = await res.json();
                        console.log("📦 DATA MAESTRA:", data);

                        const dataset = data.data || data;

                        if (!Array.isArray(dataset)) {
                            throw new Error("Formato inválido de respuesta de docentes");
                        }

                        maestraTotalPages = data.total_pages || 1;
                        document.getElementById('doc-maestra-total').textContent = data.total || 0;
                        document.getElementById('doc-maestra-indicator').textContent = `${page} / ${maestraTotalPages}`;
                        document.getElementById('doc-maestra-prev').disabled = page <= 1;
                        document.getElementById('doc-maestra-next').disabled = page >= maestraTotalPages;

                        const tbody = document.getElementById('doc-maestra-body');
                        tbody.innerHTML = '';

                        if (dataset.length === 0) {
                            tbody.innerHTML = '<tr><td colspan="7" class="px-4 py-10 text-center text-slate-400">Sin resultados</td></tr>';
                            return;
                        }

                        dataset.forEach(t => {
                            const activeBadge = t.is_active
                                ? `<button onclick="handleStatusClick(${t.id}, true, '${t.last_name}, ${t.first_name}')" class="bg-emerald-100 text-emerald-700 text-[10px] font-black px-3 py-1 rounded-full border border-emerald-200 hover:bg-emerald-200 transition-colors shadow-sm">ACTIVO</button>`
                                : `<button onclick="handleStatusClick(${t.id}, false, '${t.last_name}, ${t.first_name}')" class="bg-rose-100 text-rose-700 text-[10px] font-black px-3 py-1 rounded-full border border-rose-200 hover:bg-rose-200 transition-colors shadow-sm">INACTIVO</button>`;

                            tbody.insertAdjacentHTML('beforeend', `<tr class="hover:bg-slate-50 transition-colors" data-teacher-id="${t.id}">
                        <td class="px-4 py-3 w-10">
                            <input type="checkbox" data-id="${t.id}" onchange="updateMergeSelection()" class="merge-checkbox rounded border-slate-300 text-indigo-600 focus:ring-indigo-500">
                        </td>
                        <td class="px-4 py-3 font-bold text-slate-800">
                            ${t.last_name}
                            ${t.is_potential_duplicate ? '<i class="fa-solid fa-triangle-exclamation text-amber-500 ml-1" title="Posible duplicado detectado"></i>' : ''}
                        </td>
                        <td class="px-4 py-3 text-slate-700">${t.first_name}</td>
                        <td class="px-4 py-3 font-mono text-xs text-slate-500">${t.dni || '—'}</td>
                        <td class="px-4 py-3 text-xs text-slate-500">${t.razon_social || '—'}</td>
                        <td class="px-4 py-3 text-center status-cell">${activeBadge}</td>
                        <td class="px-4 py-3 text-right">
                            <button onclick='openTeacherModal(${JSON.stringify(t)})'
                                class="text-indigo-600 hover:bg-indigo-50 border border-indigo-100 text-xs font-bold px-3 py-1.5 rounded-lg">
                                <i class="fa-solid fa-pen"></i> Editar
                            </button>
                        </td>
                    </tr>`);
                        });

                    } catch (err) {
                        console.error("❌ ERROR MAESTRA:", err);
                    } finally {
                        console.log("🧹 MAESTRA finalizada");
                    }
                }

                // --- Status Toggle Logic v3.10 ---
                let currentStatusTarget = null;

                async function handleStatusClick(id, currentStatus, name) {
                    currentStatusTarget = { id, currentStatus, name };
                    const modal = document.getElementById('teacher-status-modal');
                    const title = document.getElementById('status-modal-title');
                    const msg = document.getElementById('status-modal-msg');
                    const icon = document.getElementById('status-modal-icon');
                    const warning = document.getElementById('status-activity-warning');
                    const btn = document.getElementById('btn-status-confirm');

                    // Reset UI
                    warning.classList.add('hidden');
                    btn.innerHTML = 'Cargando...';
                    btn.disabled = true;

                    // Setup texts
                    title.textContent = currentStatus ? '¿Desactivar Docente?' : '¿Activar Docente?';
                    msg.innerHTML = currentStatus
                        ? `Vas a desactivar a <strong>${name}</strong>. No aparecerá en el RPT Planilla.`
                        : `Vas a reactivar a <strong>${name}</strong>. Volverá a aparecer en el RPT Planilla.`;

                    icon.className = `w-20 h-20 mx-auto rounded-full flex items-center justify-center mb-6 text-3xl shadow-lg animate-bounce-slow ${currentStatus ? 'bg-rose-100 text-rose-600' : 'bg-emerald-100 text-emerald-600'}`;

                    modal.classList.remove('hidden');

                    // Backend Check for Activity (Lessons/Observations)
                    try {
                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/docentes/${id}/actividad`);
                        const json = await res.json();
                        if ((json.success || json.data) && currentStatus) {
                            const hasActivity = (json.data && (json.data.has_lessons || json.data.has_observations)) || false;
                            if (hasActivity) warning.classList.remove('hidden');
                        }
                    } catch (e) { console.error("Error checking activity:", e); }

                    btn.innerHTML = 'SÍ, CONFIRMAR';
                    btn.disabled = false;
                }

                function closeStatusModal() {
                    document.getElementById('teacher-status-modal').classList.add('hidden');
                    currentStatusTarget = null;
                }

                async function confirmStatusChange() {
                    if (!currentStatusTarget) return;
                    const { id, currentStatus } = currentStatusTarget;
                    const btn = document.getElementById('btn-status-confirm');
                    const origText = btn.innerHTML;

                    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-1"></i> Procesando...';
                    btn.disabled = true;

                    try {
                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/docentes/${id}/estado`, {
                            method: 'PATCH',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ is_active: !currentStatus })
                        });
                        const data = await res.json();
                        if (res.ok && (data.success || data)) {
                            closeStatusModal();
                            const row = document.querySelector(`tr[data-teacher-id="${id}"]`);
                            if (row) {
                                const cell = row.querySelector('.status-cell');
                                const newStatus = !currentStatus;
                                const teacherName = currentStatusTarget.name;
                                cell.innerHTML = newStatus
                                    ? `<button onclick="handleStatusClick(${id}, true, '${teacherName}')" class="bg-emerald-100 text-emerald-700 text-[10px] font-black px-3 py-1 rounded-full border border-emerald-200 hover:bg-emerald-200 transition-colors shadow-sm scale-in">ACTIVO</button>`
                                    : `<button onclick="handleStatusClick(${id}, false, '${teacherName}')" class="bg-rose-100 text-rose-700 text-[10px] font-black px-3 py-1 rounded-full border border-rose-200 hover:bg-rose-200 transition-colors shadow-sm scale-in">INACTIVO</button>`;
                            } else {
                                loadMaestra(maestraPage);
                            }
                        } else {
                            alert('Error: ' + (data.detail || 'No se pudo actualizar el estado.'));
                        }
                    } catch (e) {
                        alert('Error de conexión: ' + e.message);
                    } finally {
                        btn.innerHTML = origText;
                        btn.disabled = false;
                    }
                }
                function changeMaestraPage(delta) { loadMaestra(maestraPage + delta); }

                // ── Merge Logic ───────────────────────────────────
                function updateMergeSelection() {
                    const selected = document.querySelectorAll('input.merge-checkbox:checked');
                    const count = selected.length;
                    const btn = document.getElementById('btn-merge-docentes');
                    if (btn) {
                        btn.disabled = count !== 2;
                        btn.innerHTML = `<i class="fa-solid fa-code-merge mr-1"></i> Fusionar (${count})`;
                    }
                }

                function openMergeModal() {
                    const selectedCheckBoxes = [...document.querySelectorAll('input.merge-checkbox:checked')];
                    const selectedIds = selectedCheckBoxes.map(cb => parseInt(cb.dataset.id));
                    if (selectedIds.length !== 2) { alert('Selecciona 2 docentes.'); return; }

                    const teachers = lastMaestraData.filter(t => selectedIds.includes(t.id));
                    if (teachers.length !== 2) { alert('Error de sincronización.'); return; }

                    currentMergeData = teachers;
                    [0, 1].forEach(i => {
                        const t = teachers[i];
                        document.getElementById(`merge-name-${i}`).textContent = `${t.last_name}, ${t.first_name}`;
                        document.getElementById(`merge-dni-${i}`).textContent = t.dni || 'SIN DNI';
                        document.getElementById(`merge-rs-${i}`).textContent = t.razon_social || '—';
                        const bc = document.getElementById(`merge-badge-${i}`);
                        if (bc) bc.innerHTML = t.is_potential_duplicate ? '<span class="bg-amber-100 text-amber-700 text-[10px] font-black px-2 py-0.5 rounded-full">POSIBLE DUPLICADO</span>' : '';
                    });

                    let preselectIdx = -1;
                    const h0 = !!teachers[0].dni, h1 = !!teachers[1].dni;
                    if (h0 && !h1) preselectIdx = 0; else if (!h0 && h1) preselectIdx = 1;

                    resetMergeUI();
                    if (preselectIdx !== -1) selectPrincipal(preselectIdx);
                    document.getElementById('merge-modal').classList.remove('hidden');
                }

                function resetMergeUI() {
                    [0, 1].forEach(i => {
                        const card = document.getElementById(`merge-card-${i}`);
                        if (card) card.classList.remove('border-indigo-600', 'bg-indigo-50/30', 'ring-4', 'ring-indigo-100');
                        const radio = document.getElementById(`radio-p-${i}`);
                        if (radio) radio.checked = false;
                    });
                    const cb = document.getElementById('btn-confirm-merge');
                    if (cb) cb.disabled = true;
                }

                function selectPrincipal(idx) {
                    resetMergeUI();
                    const card = document.getElementById(`merge-card-${idx}`);
                    if (card) card.classList.add('border-indigo-600', 'bg-indigo-50/30', 'ring-4', 'ring-indigo-100');
                    const radio = document.getElementById(`radio-p-${idx}`);
                    if (radio) radio.checked = true;
                    const cb = document.getElementById('btn-confirm-merge');
                    if (cb) cb.disabled = false;
                }

                function closeMergeModal() { document.getElementById('merge-modal').classList.add('hidden'); }

                async function executeMerge() {
                    const idx = document.getElementById('radio-p-0').checked ? 0 : 1;
                    const main = currentMergeData[idx], merge = currentMergeData[1 - idx];
                    if (!confirm(`Fusionar? Principal: ${main.last_name}`)) return;

                    if (!global.hasPermission('gestionar_docentes')) {
                        alert("No tienes permiso 'gestionar_docentes' para fusionar.");
                        return;
                    }

                    const btn = document.getElementById('btn-confirm-merge');
                    const orig = btn.innerHTML;
                    btn.disabled = true; btn.innerHTML = 'Fusionando...';

                    try {
                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/docentes/fusionar`, {
                            method: 'POST', headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ teacher_main_id: main.id, teacher_merge_id: merge.id })
                        });
                        if (res.ok) { alert('Éxito.'); closeMergeModal(); loadMaestra(maestraPage); }
                        else { const d = await res.json(); alert('Error: ' + d.detail); }
                    } catch (e) { alert(e.message); } finally { btn.disabled = false; btn.innerHTML = orig; }
                }

                function openTeacherModal(t = null) {
                    document.getElementById('teacher-modal-id').value = t?.id || '';
                    document.getElementById('teacher-modal-title').textContent = t ? 'Editar Docente' : 'Nuevo Docente';
                    document.getElementById('teacher-modal-lastname').value = t?.last_name || '';
                    document.getElementById('teacher-modal-firstname').value = t?.first_name || '';
                    document.getElementById('teacher-modal-dni').value = t?.dni || '';
                    document.getElementById('teacher-modal-razon').value = t?.razon_social || '';
                    document.getElementById('teacher-modal').classList.remove('hidden');
                }
                function closeTeacherModal() { document.getElementById('teacher-modal').classList.add('hidden'); }

                async function saveTeacher() {
                    const id = document.getElementById('teacher-modal-id').value;
                    const payload = {
                        last_name: document.getElementById('teacher-modal-lastname').value.trim(),
                        first_name: document.getElementById('teacher-modal-firstname').value.trim(),
                        dni: document.getElementById('teacher-modal-dni').value.trim() || null,
                        razon_social: document.getElementById('teacher-modal-razon').value.trim() || null,
                    };
                    if (!global.hasPermission('gestionar_docentes')) {
                        alert("No tienes permiso 'gestionar_docentes' para guardar.");
                        return;
                    }

                    if (!payload.last_name || !payload.first_name) { alert('Campos obligatorios'); return; }
                    try {
                        const url = id ? `${window.CONFIG.BASE_URL}/api/docentes/${id}` : `${window.CONFIG.BASE_URL}/api/docentes`;
                        const meth = id ? 'PUT' : 'POST';
                        const res = await authFetch(url, { method: meth, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
                        if (res.ok) { closeTeacherModal(); loadMaestra(maestraPage); }
                        else { const d = await res.json(); alert('Error: ' + d.detail); }
                    } catch (e) { alert(e.message); }
                }

                async function loadSinAsignar(page = 1) {
                    sinAsignarPage = page;
                    try {
                        const data = await authFetch(`${window.CONFIG.BASE_URL}/api/docentes/sinasignar?page=${page}&limit=20`).then(r => r.json());
                        const dataset = data.data || data;
                        sinAsignarTotalPages = data.total_pages || 1;
                        document.getElementById('doc-sinasignar-total').textContent = data.total || 0;
                        document.getElementById('doc-sa-indicator').textContent = `${page} / ${sinAsignarTotalPages}`;
                        document.getElementById('doc-sa-prev').disabled = page <= 1;
                        document.getElementById('doc-sa-next').disabled = page >= sinAsignarTotalPages;

                        const tbody = document.getElementById('doc-sinasignar-body');
                        tbody.innerHTML = '';
                        if (!dataset.length) { tbody.innerHTML = '<tr><td colspan="8">Sin datos</td></tr>'; return; }
                        dataset.forEach(s => {
                            tbody.insertAdjacentHTML('beforeend', `<tr class="hover:bg-slate-50">
                        <td class="px-4 py-3 font-bold">${s.apellidos}</td>
                        <td class="px-4 py-3">${s.nombres}</td>
                        <td class="px-4 py-3 font-mono text-xs">${s.dni || '—'}</td>
                        <td class="px-4 py-3 text-xs">${s.razon_social || '—'}</td>
                        <td class="px-4 py-3 text-center text-[10px] font-black">${s.source}</td>
                        <td class="px-4 py-3 text-center">${s.times_detected}x</td>
                        <td class="px-4 py-3 text-xs">${s.last_seen_at || ''}</td>
                        <td class="px-4 py-3 text-right">
                            <button onclick='openSinAsignarModal(${JSON.stringify(s)})' class="text-indigo-600"><i class="fa-solid fa-pen"></i></button>
                            <button onclick="deleteSinAsignar(${s.id})" class="text-rose-500 ml-2"><i class="fa-solid fa-trash-can"></i></button>
                        </td>
                    </tr>`);
                        });
                    } catch (e) { console.error(e); }
                }
                function changeSinAsignarPage(delta) { loadSinAsignar(sinAsignarPage + delta); }

                function openSinAsignarModal(obj) {
                    document.getElementById('sinasignar-modal-id').value = obj.id;
                    document.getElementById('sa-modal-apellidos').value = obj.apellidos || '';
                    document.getElementById('sa-modal-nombres').value = obj.nombres || '';
                    document.getElementById('sa-modal-dni').value = obj.dni || '';
                    document.getElementById('sa-modal-razon').value = obj.razon_social || '';
                    document.getElementById('sinasignar-modal').classList.remove('hidden');
                }
                function closeSinAsignarModal() { document.getElementById('sinasignar-modal').classList.add('hidden'); }

                async function saveSinAsignar() {
                    const id = document.getElementById('sinasignar-modal-id').value;
                    const payload = {
                        apellidos: document.getElementById('sa-modal-apellidos').value.trim(),
                        nombres: document.getElementById('sa-modal-nombres').value.trim(),
                        dni: document.getElementById('sa-modal-dni').value.trim() || null,
                        razon_social: document.getElementById('sa-modal-razon').value.trim() || null,
                    };
                    try {
                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/docentes/sinasignar/${id}`, {
                            method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
                        });
                        if (res.ok) { closeSinAsignarModal(); loadSinAsignar(sinAsignarPage); }
                    } catch (e) { alert(e.message); }
                }

                async function promoteSinAsignar() {
                    const id = document.getElementById('sinasignar-modal-id').value;
                    if (!confirm('¿Promover?')) return;
                    await saveSinAsignar();
                    try {
                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/docentes/sinasignar/${id}/promote`, { method: 'POST' });
                        if (res.ok) { closeSinAsignarModal(); loadSinAsignar(1); alert('Docente promovido.'); }
                    } catch (e) { alert(e.message); }
                }

                async function deleteSinAsignar(id) {
                    if (!confirm('¿Eliminar?')) return;
                    try {
                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/docentes/sinasignar/${id}`, { method: 'DELETE' });
                        if (res.ok) loadSinAsignar(sinAsignarPage);
                    } catch (e) { alert(e.message); }
                }

                async function runReprocesarHistorico() {
                    const btn = event.currentTarget;
                    const orig = btn.innerHTML;
                    btn.disabled = true; btn.innerHTML = 'Procesando...';
                    try {
                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/docentes/reprocesar-historico`, { method: 'POST' });
                        const data = await res.json();
                        if (res.ok) {
                            lastConflicts = data.posibles_coincidencias_fuzzy || [];
                            const cb = document.getElementById('conflictos-badge');
                            cb.textContent = lastConflicts.length;
                            cb.classList.toggle('hidden', lastConflicts.length === 0);
                            alert('Reprocesamiento completado.');
                            loadSinAsignar(1);
                            renderConflictos(lastConflicts);
                        }
                    } catch (e) { alert(e.message); } finally { btn.disabled = false; btn.innerHTML = orig; }
                }

                function renderConflictos(conflicts) {
                    const tbody = document.getElementById('doc-conflictos-body');
                    if (!tbody) return;
                    tbody.innerHTML = '';
                    conflicts?.forEach(c => {
                        tbody.insertAdjacentHTML('beforeend', `<tr>
                    <td>${c.detected}</td>
                    <td>${c.suggested_norm}</td>
                    <td>${c.score}%</td>
                    <td><button onclick="vincularAlias(${c.teacher_id}, '${c.suggested_norm}')">Vincular</button></td>
                </tr>`);
                    });
                }

                async function vincularAlias(teacherId, targetNorm) {
                    if (!confirm(`Vincular a ${targetNorm}?`)) return;
                    try {
                        const res = await authFetch(`${window.CONFIG.BASE_URL}/api/docentes/vincular-alias`, {
                            method: 'POST', headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ teacher_id: teacherId, target_norm: targetNorm })
                        });
                        if (res.ok) {
                            alert('Vinculado.');
                            lastConflicts = lastConflicts.filter(c => c.teacher_id !== teacherId);
                            renderConflictos(lastConflicts);
                        }
                    } catch (e) { alert(e.message); }
                }

                // --- GLOBAL EXPORTS: CONFIG & CORE ---
                global.loadConfig = loadConfig;
                global.saveConfig = saveConfig;
                global.deleteConfig = deleteConfig;
                global.editConfig = editConfig;
                global.openConfigModal = openConfigModal;
                global.closeConfigModal = closeConfigModal;
                global.calculateDuration = calculateDuration;
                global.calculateDurationMinutes = calculateDurationMinutes;

                // --- GLOBAL EXPORTS: DOCENTES (MAESTRA) ---
                global.loadMaestra = loadMaestra;
                global.loadSinAsignar = loadSinAsignar;
                global.saveTeacher = saveTeacher;
                global.executeMerge = executeMerge;
                global.changeMaestraPage = changeMaestraPage;
                global.changeSinAsignarPage = changeSinAsignarPage;
                global.changeImportPage = changeImportPage;
                global.openTeacherModal = openTeacherModal;
                global.closeTeacherModal = closeTeacherModal;
                global.openSinAsignarModal = openSinAsignarModal;
                global.closeSinAsignarModal = closeSinAsignarModal;
                global.openMergeModal = openMergeModal;
                global.closeMergeModal = closeMergeModal;
                global.closeStatusModal = closeStatusModal;
                global.handleStatusClick = handleStatusClick;
                global.confirmStatusChange = confirmStatusChange;
                global.selectPrincipal = selectPrincipal;
                global.toggleDocentesTab = toggleDocentesTab;
                global.vincularAlias = vincularAlias;
                global.promoteSinAsignar = promoteSinAsignar;
                global.uploadDocentesExcel = uploadDocentesExcel;
                global.runReprocesarHistorico = runReprocesarHistorico;

                // --- GLOBAL EXPORTS: RPT PLANILLA ---
                global.loadRptPlanilla = loadRptPlanilla;
                global.loadRptCatalogs = loadRptCatalogs;
                global.changeRptPage = changeRptPage;
                global.exportToExcel = exportToExcel;
                global.handleSedeChange = handleSedeChange;

                // --- GLOBAL EXPORTS: UPLOAD & HISTORY ---
                global.simulateUpload = simulateUpload;
                global.loadUploadHistory = loadUploadHistory;
                global.changeHistoryPage = changeHistoryPage;
                global.resetUpload = resetUpload;
                global.updateFileName = updateFileName;
                global.confirmOverwrite = confirmOverwrite;
                global.closeOverwriteModal = closeOverwriteModal;

                // --- GLOBAL EXPORTS: OBSERVATIONS (LEGACY) ---
                global.loadObsLogs = loadObsLogs;
                global.saveObservation = saveObservation;
                global.deleteObservation = deleteObservation;
                global.loadObsTeacherList = loadObsTeacherList;
                global.searchClassesForObs = searchClassesForObs;
                global.handleObsTypeChange = handleObsTypeChange;
                global.toggleObsTab = toggleObsTab;
                global.toggleObsBlockMode = toggleObsBlockMode;
                global.openRegisterObsModal = openRegisterObsModal;
                global.closeObsRegisterModal = closeObsRegisterModal;
                global.closeObsConfirmModal = closeObsConfirmModal;

                // --- GLOBAL EXPORTS: SCHEDULE VISOR ---
                global.loadSchedule = loadSchedule;
                global.renderScheduleGrid = renderScheduleGrid;
                global.toggleSlotReplacement = toggleSlotReplacement;
                global.exportSchedule = exportSchedule;
                global.toggleConfigMenu = toggleConfigMenu;
                global.nav = nav;

            })(window);

            // ==========================================
            // INITIALIZATION BOOTSTRAP
            // ==========================================
            document.addEventListener('DOMContentLoaded', async () => {
                if (global.initApp) {
                    await global.initApp();
                }
            });

        </script>
</body>
</html>